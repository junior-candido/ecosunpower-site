---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'EcoSunPower — Energia Solar com Tecnologia em Brasília e Goiás',
  description = 'Especialistas em energia solar com baterias, Grid Zero e sistemas híbridos. 600+ projetos entregues em Brasília e Goiás. Liberte sua casa ou empresa da conta de luz.',
  ogImage = '/og-image.png',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1FB8E8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="EcoSunPower" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="EcoSunPower" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="EcoSunPower" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Preconnect Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: 'EcoSunPower Energia Solar',
      description: description,
      url: 'https://ecosunpower.eng.br',
      telephone: '+5561998805002',
      email: 'junior@ecosunpower.eng.br',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Brasília',
        addressRegion: 'DF',
        addressCountry: 'BR',
      },
      areaServed: ['Brasília', 'Distrito Federal', 'Goiás'],
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- PWA Install Prompt -->
    <div id="pwa-install-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:right-6 md:bottom-6 md:max-w-sm bg-white rounded-2xl shadow-2xl border-2 border-primary-200 p-4 hidden z-50 animate-fade-in-up">
      <div class="flex items-start gap-3">
        <img src="/icon-192.png" alt="EcoSunPower" class="w-12 h-12 rounded-xl flex-shrink-0" />
        <div class="flex-1 min-w-0">
          <h3 class="font-bold text-dark text-sm">Instalar EcoSunPower</h3>
          <p class="text-xs text-muted mt-0.5 leading-snug">
            Adicione à tela inicial pra acesso rápido + funciona offline.
          </p>
          <div class="flex gap-2 mt-3">
            <button id="pwa-install-btn" class="flex-1 px-3 py-2 bg-primary-500 hover:bg-primary-600 text-white text-xs font-bold rounded-lg transition-colors">
              ⚡ Instalar
            </button>
            <button id="pwa-dismiss-btn" class="px-3 py-2 text-muted hover:text-dark text-xs font-semibold transition-colors">
              Agora não
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Register Service Worker + PWA Install -->
    <script is:inline>
      // Register Service Worker
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch((err) => console.warn('SW falhou:', err));
        });
      }

      // PWA Install prompt
      let deferredPrompt;
      const banner = document.getElementById('pwa-install-banner');
      const installBtn = document.getElementById('pwa-install-btn');
      const dismissBtn = document.getElementById('pwa-dismiss-btn');

      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        // Mostra banner depois de 5s pro usuário ter contato com site
        const dismissed = localStorage.getItem('pwa-dismissed');
        if (!dismissed) {
          setTimeout(() => banner?.classList.remove('hidden'), 5000);
        }
      });

      installBtn?.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        await deferredPrompt.userChoice;
        deferredPrompt = null;
        banner?.classList.add('hidden');
      });

      dismissBtn?.addEventListener('click', () => {
        banner?.classList.add('hidden');
        localStorage.setItem('pwa-dismissed', String(Date.now()));
      });

      // Detecta quando instalado
      window.addEventListener('appinstalled', () => {
        banner?.classList.add('hidden');
        deferredPrompt = null;
      });
    </script>
  </body>
</html>

---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, category, tags, author, authorRole, readingTime, sourceAttribution } = post.data;

const dateFmt = (d: Date) => new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }).format(d);

const categoryLabel: Record<string, string> = {
  tecnico: 'Técnico',
  tecnologia: 'Tecnologia',
  mercado: 'Mercado',
  regulacao: 'Regulação',
  casos: 'Casos',
  tutorial: 'Tutorial',
};

const url = `https://ecosunpower.eng.br/blog/${post.slug}/`;
---

<Layout title={`${title} — Blog EcoSunPower`} description={description}>
  <!-- JSON-LD Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    'headline': title,
    'description': description,
    'image': heroImage ? `https://ecosunpower.eng.br${heroImage}` : 'https://ecosunpower.eng.br/og-image.png',
    'datePublished': pubDate.toISOString(),
    'dateModified': (updatedDate ?? pubDate).toISOString(),
    'author': {
      '@type': 'Person',
      'name': author,
      'jobTitle': authorRole,
      'worksFor': {
        '@type': 'Organization',
        'name': 'ECOSUNPOWER ENERGIA SOLAR LTDA'
      }
    },
    'publisher': {
      '@type': 'Organization',
      'name': 'EcoSunPower',
      'logo': {
        '@type': 'ImageObject',
        'url': 'https://ecosunpower.eng.br/logo-ecosunpower.png'
      }
    },
    'mainEntityOfPage': {
      '@type': 'WebPage',
      '@id': url
    },
    'articleSection': categoryLabel[category],
    'keywords': tags.join(', '),
  })}></script>

  <article class="bg-navy">
    <!-- Hero -->
    {heroImage && (
      <div class="relative aspect-[16/9] md:aspect-[21/9] w-full bg-navy-800 overflow-hidden">
        <img
          src={heroImage}
          alt={heroImageAlt ?? title}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/40 to-transparent"></div>
      </div>
    )}

    <!-- Header -->
    <header class={`${heroImage ? '-mt-32 relative z-10' : 'pt-16'}`}>
      <div class="container-narrow">
        <div class={`${heroImage ? 'bg-navy-700 border border-navy-line rounded-t-2xl p-8 md:p-12 shadow-xl' : ''}`}>
          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-sm text-ink-mut mb-5" aria-label="breadcrumb">
            <a href="/" class="hover:text-primary-400">Início</a>
            <span class="opacity-40">/</span>
            <a href="/blog" class="hover:text-primary-400">Blog</a>
            <span class="opacity-40">/</span>
            <span class="text-ink font-medium truncate">{title}</span>
          </nav>

          <!-- Category badge -->
          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="inline-flex items-center px-3 py-1 bg-primary-500/15 text-primary-400 rounded-full text-xs font-bold uppercase tracking-wider">
              {categoryLabel[category]}
            </span>
            {readingTime && (
              <span class="text-xs text-ink-mut">{readingTime} min de leitura</span>
            )}
          </div>

          <!-- Title -->
          <h1 class="text-3xl md:text-5xl font-display font-bold leading-tight mb-5 text-ink">
            {title}
          </h1>

          <!-- Description -->
          <p class="text-lg md:text-xl text-ink-mut leading-relaxed mb-8">
            {description}
          </p>

          <!-- Author + Date -->
          <div class="flex items-center justify-between flex-wrap gap-4 pb-8 border-b border-navy-line">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center text-white font-bold text-lg">
                {author.split(' ').map(n => n[0]).slice(0,2).join('')}
              </div>
              <div>
                <p class="font-bold text-ink">{author}</p>
                <p class="text-xs text-ink-mut">{authorRole}</p>
              </div>
            </div>
            <div class="text-sm text-ink-mut">
              <time datetime={pubDate.toISOString()}>{dateFmt(pubDate)}</time>
              {updatedDate && (
                <span class="block text-xs">Atualizado em {dateFmt(updatedDate)}</span>
              )}
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Content -->
    <div class="container-narrow py-12">
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-ink
        prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-5
        prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4
        prose-p:text-base prose-p:leading-relaxed prose-p:text-ink-mut
        prose-a:text-primary-400 prose-a:font-semibold hover:prose-a:text-primary-300 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-ink
        prose-li:text-ink-mut
        prose-blockquote:border-l-accent-500 prose-blockquote:bg-accent-500/10 prose-blockquote:text-ink-mut prose-blockquote:py-2 prose-blockquote:px-4 prose-blockquote:not-italic
        prose-table:text-sm prose-th:bg-primary-500/15 prose-th:text-primary-300
        prose-img:rounded-xl prose-img:shadow-md
        prose-code:bg-navy-600 prose-code:text-ink prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none">
        <slot />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mt-12 pt-8 border-t border-navy-line">
          <p class="text-sm text-ink-mut mb-3">Tags:</p>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="inline-flex items-center px-3 py-1 bg-navy-600 text-ink-mut rounded-full text-xs font-medium hover:bg-primary-500/15 hover:text-primary-400 transition-colors">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Source attribution -->
      {sourceAttribution && (
        <div class="mt-8 p-4 bg-navy-700 border border-navy-line rounded-xl text-sm text-ink-mut">
          <p><strong class="text-ink">Fonte:</strong> {sourceAttribution}</p>
        </div>
      )}

      <!-- Author CTA -->
      <div class="mt-12 p-8 bg-gradient-to-br from-primary-600 to-primary-800 rounded-2xl text-white">
        <h3 class="text-2xl font-bold mb-3">Quer falar com a EcoSunPower?</h3>
        <p class="text-white/90 mb-5">
          Tem dúvida sobre energia solar pra sua casa, comércio ou indústria? A gente atende em Brasília-DF
          e Goiás (até 100 km do Entorno). Resposta no zap em minutos.
        </p>
        <a
          href={`https://wa.me/5561998805002?text=${encodeURIComponent(`Oi! Vi o post "${title}" no blog e queria conversar.`)}`}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-dark font-bold px-6 py-3 rounded-xl transition-colors"
        >
          Falar no WhatsApp
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
        </a>
      </div>
    </div>
  </article>
</Layout>

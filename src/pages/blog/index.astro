---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featured = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const rest = featured ? allPosts.filter((p) => p.slug !== featured.slug) : allPosts;

const dateFmt = (d: Date) => new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }).format(d);

const categoryLabel: Record<string, string> = {
  tecnico: 'Técnico',
  tecnologia: 'Tecnologia',
  mercado: 'Mercado',
  regulacao: 'Regulação',
  casos: 'Casos',
  tutorial: 'Tutorial',
};

const categoryGradient: Record<string, string> = {
  tecnico: 'from-primary-500 to-primary-700',
  tecnologia: 'from-primary-600 to-dark',
  mercado: 'from-accent-400 to-accent-600',
  regulacao: 'from-primary-700 to-dark',
  casos: 'from-accent-500 to-primary-600',
  tutorial: 'from-primary-400 to-accent-500',
};

const categoryIcon: Record<string, string> = {
  tecnico: 'M11 4a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 01-1 1h-2a1 1 0 01-1-1V4zM5 12a1 1 0 011-1h12a1 1 0 011 1v8a1 1 0 01-1 1H6a1 1 0 01-1-1v-8z',
  tecnologia: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25',
  mercado: 'M2.25 18L9 11.25l4.306 4.306a11.95 11.95 0 015.814-5.518l2.74-1.22m0 0l-5.94-2.281m5.94 2.281l-2.28 5.941',
  regulacao: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
  casos: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z',
  tutorial: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25',
};

const categoriesUsed = Array.from(new Set(allPosts.map((p) => p.data.category)));
const hasAnyPost = allPosts.length > 0;
---

<Layout
  title="Blog — EcoSunPower Energia Solar"
  description="Artigos técnicos sobre energia solar, baterias, autoconsumo, mercado livre e o setor de energia limpa em Brasília-DF e Goiás."
>
  <section class="bg-gradient-hero text-white py-16 lg:py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-sun opacity-50"></div>
    <div class="absolute -top-20 -right-20 w-96 h-96 bg-accent-500/20 rounded-full blur-3xl animate-pulse-soft"></div>
    <div class="container-narrow relative z-10 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-6 text-sm font-semibold">
        ⚡ Conteúdo técnico — energia solar, baterias e mercado
      </span>
      <h1 class="text-4xl lg:text-6xl mb-5">Blog EcoSunPower</h1>
      <p class="text-lg lg:text-xl text-slate-100/90 max-w-2xl mx-auto mb-8">
        Insights práticos do dia a dia da engenharia solar em Brasília-DF e Goiás.
      </p>

      {hasAnyPost && (
        <div class="max-w-2xl mx-auto">
          <div class="relative">
            <input
              type="text"
              id="blog-search"
              placeholder="Buscar artigo (digite título, palavra-chave ou tema)..."
              class="w-full px-6 py-4 pl-14 pr-12 bg-white text-dark placeholder-slate-400 rounded-2xl shadow-xl focus:outline-none focus:ring-4 focus:ring-accent-400/40 text-base"
              autocomplete="off"
            />
            <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
            </svg>
            <button id="blog-search-clear" type="button" class="hidden absolute right-4 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-slate-100 hover:bg-slate-200 flex items-center justify-center text-slate-500" aria-label="Limpar busca">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        </div>
      )}
    </div>
  </section>

  {!hasAnyPost && (
    <section class="section bg-surface-alt">
      <div class="container-wide">
        <div class="max-w-2xl mx-auto text-center bg-white rounded-3xl p-12 shadow-card">
          <div class="text-6xl mb-6">📝</div>
          <h2 class="text-3xl mb-4">Em construção</h2>
          <p class="text-muted leading-relaxed mb-8">
            Estamos preparando conteúdo de alto nível sobre energia solar, baterias, Grid Zero,
            autoconsumo e mercado livre. Em breve, publicações regulares.
          </p>
          <a href="https://wa.me/5561998805002?text=Oi!%20Quero%20que%20me%20avise%20quando%20o%20blog%20da%20EcoSunPower%20publicar%20artigos%20novos" target="_blank" rel="noopener" class="inline-block btn-primary">
            Avise-me quando publicar
          </a>
        </div>
      </div>
    </section>
  )}

  {hasAnyPost && (
    <section class="section bg-surface-alt">
      <div class="container-wide">
        <!-- Filtros de categoria -->
        <div class="flex items-center gap-2 mb-10 overflow-x-auto pb-2 -mx-4 px-4" id="blog-filters">
          <button data-cat="all" class="blog-filter-btn active flex-shrink-0 px-4 py-2 rounded-full text-sm font-bold uppercase tracking-wider border-2 transition-colors">
            Todos ({allPosts.length})
          </button>
          {categoriesUsed.map((cat) => {
            const count = allPosts.filter((p) => p.data.category === cat).length;
            return (
              <button data-cat={cat} class="blog-filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-bold uppercase tracking-wider border-2 transition-colors">
                {categoryLabel[cat]} ({count})
              </button>
            );
          })}
        </div>

        <!-- Empty state da busca -->
        <div id="blog-no-results" class="hidden text-center py-16 bg-white rounded-2xl shadow-card mb-12">
          <div class="text-5xl mb-4">🔍</div>
          <h3 class="text-2xl font-bold mb-2">Nenhum artigo encontrado</h3>
          <p class="text-muted">Tenta outra palavra-chave ou limpa a busca.</p>
        </div>

        <!-- Featured post -->
        {featured && (
          <a
            href={`/blog/${featured.slug}`}
            class="blog-card-featured block mb-12 group"
            data-cat={featured.data.category}
            data-search={`${featured.data.title} ${featured.data.description} ${featured.data.tags.join(' ')} ${categoryLabel[featured.data.category]}`.toLowerCase()}
          >
            <div class="bg-white rounded-3xl overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300">
              <div class="grid md:grid-cols-2 gap-0">
                {featured.data.heroImage ? (
                  <div class="aspect-[4/3] md:aspect-auto md:h-full bg-dark relative overflow-hidden">
                    <img
                      src={featured.data.heroImage}
                      alt={featured.data.heroImageAlt ?? featured.data.title}
                      class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="eager"
                    />
                  </div>
                ) : (
                  <div class={`aspect-[4/3] md:aspect-auto md:h-full relative overflow-hidden bg-gradient-to-br ${categoryGradient[featured.data.category]}`}>
                    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 30%, white 1px, transparent 2px), radial-gradient(circle at 70% 70%, white 1px, transparent 2px); background-size: 40px 40px;"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <svg class="w-32 h-32 text-white/80 group-hover:scale-110 transition-transform duration-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <path d={categoryIcon[featured.data.category]} />
                      </svg>
                    </div>
                  </div>
                )}
                <div class="p-8 md:p-12 flex flex-col justify-center">
                  <div class="flex items-center gap-2 mb-4 flex-wrap">
                    <span class="inline-flex items-center px-3 py-1 bg-accent-100 text-accent-700 rounded-full text-xs font-bold uppercase tracking-wider">
                      ⭐ Destaque
                    </span>
                    <span class="inline-flex items-center px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-xs font-bold uppercase tracking-wider">
                      {categoryLabel[featured.data.category]}
                    </span>
                  </div>
                  <h2 class="text-2xl md:text-3xl font-bold mb-4 group-hover:text-primary-600 transition-colors leading-tight">
                    {featured.data.title}
                  </h2>
                  <p class="text-muted leading-relaxed mb-6">{featured.data.description}</p>
                  <div class="flex items-center justify-between flex-wrap gap-3">
                    <div class="flex items-center gap-3 text-xs text-muted">
                      <time datetime={featured.data.pubDate.toISOString()}>{dateFmt(featured.data.pubDate)}</time>
                      {featured.data.readingTime && (
                        <>
                          <span>·</span>
                          <span>{featured.data.readingTime} min de leitura</span>
                        </>
                      )}
                    </div>
                    <span class="inline-flex items-center gap-1 text-primary-600 font-bold text-sm group-hover:gap-2 transition-all">
                      Ler artigo
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </a>
        )}

        <!-- Grid of posts -->
        {rest.length > 0 && (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
            {rest.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="blog-card group block bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 hover:-translate-y-1 flex flex-col"
                data-cat={post.data.category}
                data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')} ${categoryLabel[post.data.category]}`.toLowerCase()}
              >
                {post.data.heroImage ? (
                  <div class="aspect-[16/10] bg-dark relative overflow-hidden">
                    <img
                      src={post.data.heroImage}
                      alt={post.data.heroImageAlt ?? post.data.title}
                      class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class={`aspect-[16/10] relative overflow-hidden bg-gradient-to-br ${categoryGradient[post.data.category]}`}>
                    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 30%, white 1px, transparent 2px), radial-gradient(circle at 70% 70%, white 1px, transparent 2px); background-size: 30px 30px;"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <svg class="w-20 h-20 text-white/80 group-hover:scale-110 transition-transform duration-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <path d={categoryIcon[post.data.category]} />
                      </svg>
                    </div>
                  </div>
                )}

                <div class="p-6 flex-1 flex flex-col">
                  <span class="inline-flex items-center w-fit px-2 py-0.5 bg-primary-100 text-primary-700 rounded-full text-xs font-bold uppercase tracking-wider mb-3">
                    {categoryLabel[post.data.category]}
                  </span>
                  <h3 class="text-lg font-bold mb-2 group-hover:text-primary-600 transition-colors leading-tight line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-muted leading-relaxed mb-4 line-clamp-3 flex-1">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between pt-4 border-t border-slate-100">
                    <div class="flex items-center gap-2 text-xs text-muted">
                      <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
                      {post.data.readingTime && (
                        <>
                          <span>·</span>
                          <span>{post.data.readingTime} min</span>
                        </>
                      )}
                    </div>
                    <span class="inline-flex items-center gap-1 text-primary-600 font-bold text-xs group-hover:gap-2 transition-all">
                      Ler mais
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- CTA bottom -->
        <div class="mt-16 text-center">
          <p class="text-muted text-sm mb-4">Tem dúvida sobre energia solar? A gente responde rápido no zap.</p>
          <a href="https://wa.me/5561998805002?text=Oi!%20Vi%20o%20blog%20da%20EcoSunPower%20e%20gostei%2C%20queria%20conversar" target="_blank" rel="noopener" class="btn-primary">
            Falar com a EcoSunPower
          </a>
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Filter button states */
  .blog-filter-btn {
    background: white;
    color: #64748B;
    border-color: #E2E8F0;
  }
  .blog-filter-btn:hover {
    border-color: #1FB8E8;
    color: #0E7CB8;
  }
  .blog-filter-btn.active {
    background: linear-gradient(135deg, #1FB8E8 0%, #0E7CB8 100%);
    color: white;
    border-color: transparent;
  }
</style>

<script>
  // Busca client-side + filtro por categoria. Funciona com qualquer
  // numero de posts sem custo de servidor. Filtra cards via data-* attrs.

  const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
  const clearBtn = document.getElementById('blog-search-clear') as HTMLButtonElement | null;
  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.blog-filter-btn'));
  const noResults = document.getElementById('blog-no-results');
  const featuredEl = document.querySelector('.blog-card-featured') as HTMLElement | null;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.blog-card'));

  let activeCategory = 'all';
  let activeQuery = '';

  function normalize(s: string): string {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  function applyFilters() {
    const q = normalize(activeQuery.trim());
    const cat = activeCategory;
    let visibleCount = 0;

    // Featured
    if (featuredEl) {
      const featCat = featuredEl.dataset.cat ?? '';
      const featSearch = normalize(featuredEl.dataset.search ?? '');
      const matchesCat = cat === 'all' || featCat === cat;
      const matchesQuery = !q || featSearch.includes(q);
      const visible = matchesCat && matchesQuery;
      featuredEl.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    }

    // Grid cards
    cards.forEach((card) => {
      const cardCat = card.dataset.cat ?? '';
      const cardSearch = normalize(card.dataset.search ?? '');
      const matchesCat = cat === 'all' || cardCat === cat;
      const matchesQuery = !q || cardSearch.includes(q);
      const visible = matchesCat && matchesQuery;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      activeQuery = searchInput.value;
      if (clearBtn) clearBtn.classList.toggle('hidden', activeQuery.length === 0);
      applyFilters();
    });
  }

  if (clearBtn && searchInput) {
    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      activeQuery = '';
      clearBtn.classList.add('hidden');
      applyFilters();
      searchInput.focus();
    });
  }

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.dataset.cat ?? 'all';
      applyFilters();
    });
  });
</script>

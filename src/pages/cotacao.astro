---
import Layout from '../layouts/Layout.astro';
import casoAna from '../content/cases/07-sistema-hibrido-alto-paraiso.json';
import casoQuintas from '../content/cases/01-residencial-quintas-ipes-lago-sul.json';
import casoVilleneuve from '../content/cases/16-residencial-villeneuve-solaredge.json';
import casoSuperbom from '../content/cases/08-supermercado-superbom-total-ville.json';
import casoAmv from '../content/cases/11-distribuidora-bebidas-central.json';
import casoAilson from '../content/cases/17-usina-ailson-fernandes-planaltina.json';

const cases = [
  { ...casoQuintas, tag: 'Residencial premium · Lago Sul' },
  { ...casoVilleneuve, tag: 'Residencial · Águas Claras' },
  { ...casoAna, tag: 'Híbrido residencial · Chapada' },
  { ...casoSuperbom, tag: 'Comercial · Brasília' },
  { ...casoAmv, tag: 'Distribuidora · Brazlândia' },
  { ...casoAilson, tag: 'Usina 43kWp · Planaltina' },
];

const cidadesDF = [
  'Plano Piloto · Asa Sul · Asa Norte',
  'Lago Sul · Lago Norte',
  'Águas Claras',
  'Vicente Pires · Arniqueira',
  'Taguatinga',
  'Ceilândia',
  'Guará · Park Way',
  'Sobradinho · Sobradinho II',
  'Gama · Santa Maria',
  'Planaltina · São Sebastião',
  'Brazlândia',
  'Recanto das Emas · Samambaia',
  'Núcleo Bandeirante · Riacho Fundo',
  'Jardim Botânico · São Sebastião',
  'Outra RA do DF',
];

const cidadesGO = [
  'Valparaíso de Goiás',
  'Cidade Ocidental',
  'Jardim Ingá',
  'Luziânia',
  'Novo Gama',
  'Águas Lindas de Goiás',
  'Formosa',
  'Padre Bernardo',
  'Alto Paraíso de Goiás',
  'São João da Aliança',
  'São Gabriel de Goiás',
];

// Hero usa vídeo Superbom comprimido em public/videos/ (HD 1280x720, sem áudio, ~6.5MB)
// Poster: frame extraído do próprio Superbom (mostra algo certo enquanto vídeo carrega)
const heroVideoUrl = '/videos/cotacao-hero.mp4';
const heroPosterUrl = '/videos/cotacao-hero-poster.jpg';
---

<Layout
  title="Cotação grátis de energia solar — EcoSunPower Brasília-DF"
  description="Diagnóstico técnico gratuito em 24h. Responsável Técnico CFT/CREA, marcas Tier 1 (Trina, JA, Jinko, Risen), garantia 12 meses. Brasília-DF + Entorno."
  noChrome={true}
  noIndex={true}
>
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-700 to-slate-50">
    <!-- HEADER MINIMAL COM LOGO + SELO CFT -->
    <header class="bg-slate-900/90 backdrop-blur border-b border-slate-800 sticky top-0 z-30 shadow-xl">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <img src="/logo-ecosunpower-icon.png" alt="EcoSunPower" class="h-9 w-9 drop-shadow-[0_0_10px_rgba(255,199,44,0.4)]" />
          <div>
            <div class="font-bold text-white text-base leading-none" style="text-shadow:0 0 14px rgba(255,199,44,0.4)">EcoSunPower</div>
            <div class="text-[10px] text-primary-300 leading-tight mt-0.5">Energia solar com engenharia</div>
          </div>
        </div>
        <div class="hidden md:flex items-center gap-2 bg-accent-500/15 border border-accent-500/40 rounded-lg px-3 py-1.5">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          <div class="text-xs">
            <div class="font-bold text-accent-200 leading-none">Responsável Técnico CFT/CREA</div>
            <div class="text-[10px] text-accent-400 leading-tight mt-0.5">Registro 98940457153</div>
          </div>
        </div>
      </div>
    </header>

    <!-- HERO COM VÍDEO REAL DE INSTALAÇÃO -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700">
      <video
        id="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster={heroPosterUrl}
        class="absolute inset-0 w-full h-full object-cover opacity-40"
      >
        <source src={`${heroVideoUrl}?v=2`} type="video/mp4" />
      </video>
      <script is:inline>
        // Forca play em browsers que bloqueiam autoplay silencioso (Safari iOS, Edge antigo).
        // Ate Service Worker novo nao pegar o video corrompido antigo, cache-bust no src acima resolve.
        (function () {
          const v = document.getElementById('hero-video');
          if (!v) return;
          v.muted = true; // garante muted (autoplay so funciona muted)
          const tryPlay = () => v.play().catch(() => {});
          tryPlay();
          document.addEventListener('DOMContentLoaded', tryPlay);
          document.addEventListener('click', tryPlay, { once: true });
        })();
      </script>
      <div class="relative max-w-4xl mx-auto px-4 py-14 md:py-20 text-center">
        <div class="inline-flex items-center gap-2 bg-accent-500 text-dark px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-5 shadow-lg">
          🎯 Diagnóstico Grátis · Resposta em 24h
        </div>
        <div class="inline-block mb-3 px-3 py-1 rounded-full bg-slate-900/70 backdrop-blur border border-accent-400/40 text-xs text-accent-300 font-bold uppercase tracking-wider shadow-lg">
          📍 Brasília-DF · Entorno de Goiás (RIDE)
        </div>
        <h1 class="text-3xl md:text-5xl font-extrabold text-white leading-tight">
          Quanto a EcoSunPower vai <span class="text-accent-400">cortar da sua conta de luz</span>?
        </h1>
        <p class="mt-5 text-lg md:text-xl text-primary-100 max-w-2xl mx-auto">
          Engenharia CFT/CREA, marcas Tier 1, atendimento presencial em Brasília-DF e Entorno.
          <strong class="text-white">Sem cadastro, sem spam.</strong>
        </p>
        <a href="#calcular" class="inline-block mt-7 bg-accent-500 hover:bg-accent-400 text-dark font-bold px-7 py-4 rounded-xl text-lg shadow-2xl transition transform hover:-translate-y-0.5">
          Calcular minha economia →
        </a>
        <div class="mt-7 flex flex-wrap justify-center gap-2 text-xs font-semibold">
          <span class="px-3 py-1.5 rounded-full bg-slate-900/70 backdrop-blur text-white border border-white/30 shadow-lg">⚡ +600 projetos entregues</span>
          <span class="px-3 py-1.5 rounded-full bg-slate-900/70 backdrop-blur text-white border border-white/30 shadow-lg">🏆 Marcas Tier 1 Bloomberg</span>
          <span class="px-3 py-1.5 rounded-full bg-slate-900/70 backdrop-blur text-white border border-white/30 shadow-lg">🛡 Garantia 12 meses</span>
          <span class="px-3 py-1.5 rounded-full bg-slate-900/70 backdrop-blur text-white border border-white/30 shadow-lg">📍 Base Brasília-DF</span>
        </div>
      </div>
    </section>

    <!-- FORMULÁRIO QUALIFICADOR -->
    <section id="calcular" class="max-w-2xl mx-auto px-4 py-12 -mt-8 relative z-10">
      <div class="bg-white rounded-2xl shadow-2xl border border-slate-200 p-6 md:p-8">
        <div class="text-center mb-6">
          <span class="inline-block bg-accent-100 text-accent-700 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
            30 segundos · 2 perguntas
          </span>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mt-3">
            Calcule sua economia
          </h2>
          <p class="text-sm text-slate-600 mt-1">Continuamos pelo WhatsApp com diagnóstico técnico personalizado</p>
        </div>

        <form id="form-cotacao" class="space-y-6">
          <div>
            <label class="block text-sm font-bold text-slate-800 mb-2">1. Sua cidade</label>
            <select id="cidade" required class="w-full px-4 py-3 rounded-lg border-2 border-slate-200 focus:border-primary-500 outline-none text-slate-900 bg-white text-sm">
              <option value="">Selecione...</option>
              <optgroup label="Distrito Federal">
                {cidadesDF.map((c, i) => (
                  <option value={`df-${i}`} data-label={c}>{c}</option>
                ))}
              </optgroup>
              <optgroup label="Goiás (Entorno DF)">
                {cidadesGO.map((c, i) => (
                  <option value={`go-${i}`} data-label={c}>{c}</option>
                ))}
              </optgroup>
              <option value="fora-area" data-label="Outra cidade">Outra cidade (fora DF/GO Entorno)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-800 mb-2">2. Quanto vem na sua conta de luz?</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="conta-opt cursor-pointer p-3 border-2 border-slate-200 rounded-lg hover:border-primary-400 transition text-center">
                <input type="radio" name="conta" value="ate-500" class="sr-only" required>
                <div class="text-[10px] text-slate-500 uppercase">Até</div>
                <div class="font-bold text-slate-900">R$ 500</div>
              </label>
              <label class="conta-opt cursor-pointer p-3 border-2 border-slate-200 rounded-lg hover:border-primary-400 transition text-center">
                <input type="radio" name="conta" value="500-1000" class="sr-only" required>
                <div class="text-[10px] text-slate-500 uppercase">R$ 500 a</div>
                <div class="font-bold text-slate-900">R$ 1.000</div>
              </label>
              <label class="conta-opt cursor-pointer p-3 border-2 border-slate-200 rounded-lg hover:border-primary-400 transition text-center">
                <input type="radio" name="conta" value="1000-2000" class="sr-only" required>
                <div class="text-[10px] text-slate-500 uppercase">R$ 1.000 a</div>
                <div class="font-bold text-slate-900">R$ 2.000</div>
              </label>
              <label class="conta-opt cursor-pointer p-3 border-2 border-slate-200 rounded-lg hover:border-primary-400 transition text-center">
                <input type="radio" name="conta" value="acima-2000" class="sr-only" required>
                <div class="text-[10px] text-slate-500 uppercase">Acima de</div>
                <div class="font-bold text-slate-900">R$ 2.000</div>
              </label>
            </div>
          </div>

          <button type="submit" class="w-full bg-gradient-to-r from-primary-600 to-primary-500 hover:from-primary-700 hover:to-primary-600 text-white font-bold py-4 rounded-xl text-lg shadow-xl transition">
            Calcular minha economia →
          </button>
        </form>
      </div>

      <!-- QUALIFICADO -->
      <div id="resultado-qualificado" class="hidden mt-6 bg-white rounded-2xl shadow-2xl border-2 border-emerald-300 p-6 md:p-8 text-center">
        <div class="inline-block bg-emerald-500 text-white text-2xl rounded-full w-14 h-14 leading-[3.5rem] mb-4">🎯</div>
        <h3 class="text-2xl font-bold text-slate-900 mb-2">Perfil dentro do que atendemos!</h3>
        <p class="text-slate-700 mb-2" id="resultado-qualificado-msg">
          Atendemos sua região e seu perfil de consumo.
        </p>
        <p class="text-sm text-slate-500 mb-6">
          Resposta do Responsável Técnico CFT/CREA em até 24h.
        </p>
        <a
          id="cta-whatsapp"
          href="#"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-3 bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-8 rounded-xl text-lg shadow-2xl transition transform hover:-translate-y-0.5"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
          Falar agora no WhatsApp
        </a>
      </div>

      <!-- NÃO QUALIFICADO -->
      <div id="resultado-nao-qualificado" class="hidden mt-6 bg-amber-50 rounded-2xl shadow-md border border-amber-200 p-6 md:p-8 text-center">
        <div class="text-4xl mb-3">📋</div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">Por enquanto, ainda não compensa</h3>
        <p class="text-slate-700 mb-3">
          Atendemos sistemas onde a conta de luz fica a partir de <strong>R$ 500/mês</strong> — abaixo disso o payback fica muito longo e preferimos ser honestos com você.
        </p>
        <p class="text-sm text-slate-600">
          Sua conta aumentou recentemente (chuveiro elétrico, ar-condicionado, carro elétrico ou expansão familiar)? Volte aqui!
        </p>
      </div>

      <!-- FORA ÁREA -->
      <div id="resultado-fora-area" class="hidden mt-6 bg-slate-100 rounded-2xl shadow-md border border-slate-300 p-6 md:p-8 text-center">
        <div class="text-4xl mb-3">📍</div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">Ainda não atendemos sua região</h3>
        <p class="text-slate-700">
          Hoje atendemos <strong>Brasília-DF e Entorno de Goiás</strong> (Valparaíso, Luziânia, Cidade Ocidental, Águas Lindas, Formosa, Alto Paraíso e demais cidades próximas). Estamos expandindo — obrigado pelo interesse!
        </p>
      </div>
    </section>

    <!-- COBERTURA — DF + ENTORNO GO -->
    <section class="bg-white border-y border-slate-200 py-10">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-6">
          <span class="inline-block bg-primary-100 text-primary-700 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
            Onde atendemos
          </span>
          <h2 class="text-xl md:text-2xl font-bold text-slate-900 mt-3">
            Brasília-DF e Entorno · cobertura presencial
          </h2>
          <p class="text-sm text-slate-600 mt-1">Visitamos o local da obra, projetamos sob medida e fazemos a homologação na Neoenergia-DF ou Equatorial-GO.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-primary-50 border border-primary-200 rounded-xl p-4">
            <div class="font-bold text-primary-900 text-sm uppercase tracking-wider mb-2">🏙 Distrito Federal · todas as RAs</div>
            <div class="text-xs text-primary-700 leading-relaxed">
              Plano Piloto · Lago Sul · Lago Norte · Águas Claras · Vicente Pires · Taguatinga · Ceilândia · Guará · Park Way · Sobradinho · Gama · Santa Maria · Planaltina · Brazlândia · Núcleo Bandeirante · Riacho Fundo · Recanto das Emas · Samambaia · Jardim Botânico · São Sebastião · Arniqueira · e demais RAs
            </div>
          </div>
          <div class="bg-accent-50 border border-accent-200 rounded-xl p-4">
            <div class="font-bold text-accent-700 text-sm uppercase tracking-wider mb-2">🌿 Goiás · 11 cidades do Entorno</div>
            <div class="text-xs text-amber-800 leading-relaxed">
              Valparaíso de Goiás · Cidade Ocidental · Jardim Ingá · Luziânia · Novo Gama · Águas Lindas de Goiás · Formosa · Padre Bernardo · Alto Paraíso de Goiás · São João da Aliança · São Gabriel de Goiás
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CASES REAIS -->
    <section class="bg-white py-12 border-y border-slate-200">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-8">
          <span class="inline-block bg-primary-100 text-primary-700 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
            Quem confiou na gente
          </span>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mt-3">
            +600 projetos entregues em Brasília e Entorno
          </h2>
          <p class="text-sm text-slate-600 mt-2">Casas, condomínios, comércios e usinas. Cada um com dimensionamento próprio por engenharia.</p>
        </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {cases.map((c) => (
          <div class="group bg-white rounded-2xl overflow-hidden shadow border border-slate-200 hover:shadow-2xl hover:-translate-y-1 transition">
            <div class="aspect-video bg-slate-200 overflow-hidden">
              <img
                src={c.fotoPrincipal}
                alt={c.titulo}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
              />
            </div>
            <div class="p-4">
              <div class="text-[10px] uppercase tracking-wider text-primary-600 font-bold">{c.tag}</div>
              <div class="font-bold text-slate-900 mt-1">{(c as any).cliente ?? c.titulo}</div>
              <div class="text-xs text-slate-500 mt-0.5">{c.cidade}/{c.uf}</div>
              <div class="text-sm text-slate-700 mt-2 line-clamp-2">{c.descCurta}</div>
              {('kwp' in c && c.kwp) && (
                <div class="mt-3 inline-flex items-center gap-2 bg-emerald-50 text-emerald-800 text-xs font-bold px-2.5 py-1 rounded-full border border-emerald-200">
                  ⚡ {c.kwp} kWp
                  {('economiaMensalBrl' in c && c.economiaMensalBrl) && (
                    <span>· R$ {c.economiaMensalBrl.toLocaleString('pt-BR')}/mês</span>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
        </div>
      </div>
    </section>

    <!-- DIFERENCIAL TÉCNICO -->
    <section class="bg-gradient-to-br from-primary-50 to-accent-50 py-14">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-10">
          <span class="inline-block bg-white text-primary-700 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full shadow">
            Engenharia · não vendedor
          </span>
          <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mt-3">
            Por que somos diferentes
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-white rounded-xl p-5 shadow flex gap-4">
            <div class="text-3xl">🎓</div>
            <div>
              <div class="font-bold text-slate-900">Responsável Técnico CFT/CREA</div>
              <div class="text-sm text-slate-600 mt-1">Registro 98940457153. Projeto, ART e homologação na Neoenergia-DF ou Equatorial-GO sob responsabilidade técnica formal.</div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-5 shadow flex gap-4">
            <div class="text-3xl">🏆</div>
            <div>
              <div class="font-bold text-slate-900">Marcas Tier 1 Bloomberg</div>
              <div class="text-sm text-slate-600 mt-1">
                Painéis <strong>Trina, JA Solar, Jinko, Risen, LONGi</strong> (líderes mundiais).
                Inversores <strong>Sungrow, Solax, Hoymiles, SolarEdge</strong>. Validadas pra financiamento bancário (Santander, BV, Sicredi).
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-5 shadow flex gap-4">
            <div class="text-3xl">🛡</div>
            <div>
              <div class="font-bold text-slate-900">Garantia 12 meses</div>
              <div class="text-sm text-slate-600 mt-1">Mão de obra e instalação com 1 ano de garantia EcoSunPower. Painéis com garantia de fábrica de 25 anos (linear de potência).</div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-5 shadow flex gap-4">
            <div class="text-3xl">📊</div>
            <div>
              <div class="font-bold text-slate-900">Monitoramento em tempo real</div>
              <div class="text-sm text-slate-600 mt-1">Plataforma própria pra acompanhar geração do seu sistema 24/7. Alertas se algo cair, sem você precisar perceber primeiro.</div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-5 shadow flex gap-4">
            <div class="text-3xl">📍</div>
            <div>
              <div class="font-bold text-slate-900">Base local Brasília-DF</div>
              <div class="text-sm text-slate-600 mt-1">Empresa registrada, endereço físico, atendimento presencial quando precisar. Não somos integrador online distante.</div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-5 shadow flex gap-4">
            <div class="text-3xl">🤖</div>
            <div>
              <div class="font-bold text-slate-900">Atendimento por IA + humano</div>
              <div class="text-sm text-slate-600 mt-1">Cotação rápida via WhatsApp 24/7 (IA Eva) + atendimento técnico humano pra fechamento. Sem ficar pagando ligação ou esperando dias.</div>
            </div>
          </div>
        </div>

        <div class="text-center mt-10">
          <a href="#calcular" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-bold px-7 py-3.5 rounded-xl shadow-lg transition">
            Quero meu diagnóstico técnico →
          </a>
        </div>
      </div>
    </section>

    <!-- FOOTER MINIMAL -->
    <footer class="bg-dark text-slate-300 py-8">
      <div class="max-w-5xl mx-auto px-4 text-center text-xs space-y-2">
        <div class="flex items-center justify-center gap-2 mb-3">
          <img src="/logo-ecosunpower-icon.png" alt="EcoSunPower" class="h-7 w-7" />
          <span class="font-bold text-white text-base">EcoSunPower</span>
        </div>
        <div class="font-semibold text-slate-200">ECOSUNPOWER ENERGIA SOLAR LTDA</div>
        <div>CNPJ 33.020.459/0001-06</div>
        <div>Brasília-DF · Responsável Técnico CFT/CREA · Registro 98940457153</div>
        <div class="text-[10px] text-slate-500 pt-3">Anúncio em conformidade com legislação brasileira de publicidade. Garantia 12 meses mão de obra. Equipamentos seguem garantia de fábrica.</div>
      </div>
    </footer>
  </main>

  <script is:inline>
    (function () {
      const form = document.getElementById('form-cotacao');
      const resQualificado = document.getElementById('resultado-qualificado');
      const resNaoQualif = document.getElementById('resultado-nao-qualificado');
      const resForaArea = document.getElementById('resultado-fora-area');
      const ctaWa = document.getElementById('cta-whatsapp');
      const resQualifMsg = document.getElementById('resultado-qualificado-msg');

      document.querySelectorAll('.conta-opt input').forEach((input) => {
        input.addEventListener('change', () => {
          document.querySelectorAll('.conta-opt').forEach((opt) => {
            opt.classList.remove('border-primary-500', 'bg-primary-50');
            opt.classList.add('border-slate-200');
          });
          const parent = input.closest('.conta-opt');
          if (parent) {
            parent.classList.remove('border-slate-200');
            parent.classList.add('border-primary-500', 'bg-primary-50');
          }
        });
      });

      function getAdId() {
        const params = new URLSearchParams(window.location.search);
        const gclid = params.get('gclid');
        const utmContent = params.get('utm_content');
        const utmCampaign = params.get('utm_campaign');
        if (gclid) return 'gclid-' + gclid.slice(0, 16);
        if (utmContent) return utmContent;
        if (utmCampaign) return utmCampaign;
        return 'organic';
      }

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const cidadeSelect = document.getElementById('cidade');
        const cidadeValue = cidadeSelect.value;
        const cidadeLabel = cidadeSelect.options[cidadeSelect.selectedIndex]?.dataset?.label || cidadeValue;
        const conta = document.querySelector('input[name="conta"]:checked')?.value;
        if (!cidadeValue || !conta) return;

        resQualificado.classList.add('hidden');
        resNaoQualif.classList.add('hidden');
        resForaArea.classList.add('hidden');

        if (cidadeValue === 'fora-area') {
          resForaArea.classList.remove('hidden');
          resForaArea.scrollIntoView({ behavior: 'smooth' });
          if (typeof gtag === 'function') {
            gtag('event', 'qualificacao_fora_area', { cidade: cidadeLabel });
          }
          return;
        }

        if (conta === 'ate-500') {
          resNaoQualif.classList.remove('hidden');
          resNaoQualif.scrollIntoView({ behavior: 'smooth' });
          if (typeof gtag === 'function') {
            gtag('event', 'qualificacao_baixo_consumo', { cidade: cidadeLabel, conta: conta });
          }
          return;
        }

        const adId = getAdId();
        const contaLabel = ({
          '500-1000': 'R$ 500 a R$ 1.000',
          '1000-2000': 'R$ 1.000 a R$ 2.000',
          'acima-2000': 'acima de R$ 2.000',
        })[conta] || conta;

        const tagType = adId.startsWith('gclid-') ? 'gad' : 'ad';
        const tagId = adId.replace(/^gclid-/, '').slice(0, 16);
        const msg = 'Oi! Fiz a cotação rápida no site.\n\n' +
                    '📍 Cidade: ' + cidadeLabel + '\n' +
                    '⚡ Conta de luz: ' + contaLabel + '\n\n' +
                    'Quero o diagnóstico técnico e a proposta.\n\n' +
                    '#' + tagType + '-' + (tagId || 'organic');
        const waLink = 'https://wa.me/5561996978781?text=' + encodeURIComponent(msg);
        ctaWa.href = waLink;

        const isAltoTicket = (conta === '1000-2000' || conta === 'acima-2000');
        if (isAltoTicket) {
          resQualifMsg.textContent = 'Perfil premium. Vamos dimensionar sistema com marcas Tier 1 pra economizar até 95% da sua conta.';
        } else {
          resQualifMsg.textContent = 'Atendemos sua faixa. Vamos calcular o melhor sistema considerando payback e ROI pra você.';
        }

        resQualificado.classList.remove('hidden');
        resQualificado.scrollIntoView({ behavior: 'smooth' });

        if (typeof gtag === 'function') {
          gtag('event', 'qualificacao_completa', {
            cidade: cidadeLabel,
            conta: conta,
            ad_id: adId,
            qualificado: true,
          });
        }
      });

      ctaWa.addEventListener('click', (e) => {
        if (typeof gtag !== 'function') return;
        e.preventDefault();
        const url = ctaWa.href;
        let navigated = false;
        const go = () => {
          if (navigated) return;
          navigated = true;
          window.location = url;
        };
        gtag('event', 'click_whatsapp_qualified', {
          ad_id: getAdId(),
          event_category: 'conversion',
          event_label: 'cotacao_landing',
        });
        gtag('event', 'conversion', {
          send_to: 'AW-11322897516/tuK2CO7viuAYEOzolpcq',
          event_callback: go,
        });
        setTimeout(go, 1000);
      });
    })();
  </script>
</Layout>

---
import Layout from '../layouts/Layout.astro';

const valores = [
  {
    icon: '🛡️',
    titulo: 'Segurança e Conformidade',
    desc: 'Atuamos em conformidade com a NBR 5410, NR-10 e normas aplicáveis, garantindo sistemas seguros e confiáveis.',
  },
  {
    icon: '🤝',
    titulo: 'Transparência e Ética',
    desc: 'Trabalhamos com clareza, honestidade e responsabilidade em todas as etapas do serviço.',
  },
  {
    icon: '🏆',
    titulo: 'Qualidade e Responsabilidade',
    desc: 'Utilizamos materiais certificados e seguimos boas práticas de engenharia em cada projeto.',
  },
  {
    icon: '🎯',
    titulo: 'Foco no Cliente',
    desc: 'Desenvolvemos soluções eficientes, alinhadas às reais necessidades e objetivos de cada cliente.',
  },
  {
    icon: '🚀',
    titulo: 'Evolução Contínua',
    desc: 'Buscamos constante atualização técnica e adoção de tecnologias que gerem mais valor.',
  },
];

const certificacoes = [
  { sigla: 'NBR 5410', nome: 'Instalações Elétricas de BT' },
  { sigla: 'NBR 16690', nome: 'Sistemas Fotovoltaicos' },
  { sigla: 'NR-10', nome: 'Segurança em Eletricidade' },
  { sigla: 'CREA', nome: 'Conselho Regional de Engenharia' },
  { sigla: 'CFT', nome: 'Conselho Federal dos Técnicos Industriais' },
  { sigla: 'ART / TRT', nome: 'Responsabilidade Técnica' },
  { sigla: 'Neoenergia-DF / Equatorial-GO', nome: 'Padrões das Concessionárias' },
];
---

<Layout
  title="Sobre a EcoSunPower — Engenharia Solar com Propósito"
  description="Conheça a história da EcoSunPower: 10 anos de engenharia solar especializada em Brasília e Goiás. Missão, visão, valores e diferenciais técnicos."
>
  <!-- Hero -->
  <section class="bg-gradient-hero text-white py-20 lg:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-sun opacity-50"></div>
    <div class="absolute -top-20 -right-20 w-96 h-96 bg-accent-500/20 rounded-full blur-3xl animate-pulse-soft"></div>

    <div class="container-narrow relative z-10 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-6 text-sm font-semibold">
        ⚡ 10 anos · 600+ projetos · Engenharia própria
      </span>
      <h1 class="text-4xl lg:text-6xl mb-6 leading-tight">
        Engenharia solar<br />
        com <span class="text-accent-400">propósito</span>.
      </h1>
      <p class="text-lg lg:text-xl text-slate-100/90 max-w-2xl mx-auto leading-relaxed">
        Há 10 anos transformando contas de luz em economia,
        segurança e independência energética em Brasília e Goiás.
      </p>
    </div>
  </section>

  <!-- História -->
  <section class="section bg-white">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <div class="lg:col-span-1">
          <span class="tag-accent">Nossa história</span>
          <h2 class="text-4xl mt-4">10 anos transformando energia em liberdade</h2>
        </div>
        <div class="lg:col-span-2 space-y-5 text-lg text-muted leading-relaxed">
          <p>
            A <strong class="text-dark">EcoSunPower</strong> nasceu da convicção de que energia solar
            não é só uma alternativa — é a <strong class="text-primary-600">solução definitiva</strong>
            pra quem quer liberdade financeira, segurança elétrica e responsabilidade ambiental.
          </p>
          <p>
            Há 10 anos atuamos no mercado de energia solar fotovoltaica
            no Distrito Federal e Goiás, entregando mais de
            <strong class="text-dark">600 projetos</strong> entre residenciais,
            comerciais, rurais e industriais (Grupo A).
          </p>
          <p>
            Nossa diferença está na <strong class="text-dark">engenharia própria</strong>:
            do projeto técnico à instalação, tudo é executado pelo nosso time qualificado.
            Não terceirizamos a parte crítica. É por isso que clientes nos escolhem
            pra projetos complexos com baterias, Grid Zero, sistemas híbridos e
            mercado livre de energia.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Missão / Visão -->
  <section class="section bg-surface-alt">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Missão -->
        <div class="card border-2 border-primary-100 hover:border-primary-300 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-primary-500 text-white flex items-center justify-center text-2xl">
              🎯
            </div>
            <h3 class="text-2xl font-bold">Missão</h3>
          </div>
          <p class="text-muted leading-relaxed">
            Entregar soluções completas em energia solar fotovoltaica que gerem
            <strong class="text-dark">economia real, segurança elétrica e retorno sustentável</strong>
            para nossos clientes, atuando com excelência técnica, transparência e total
            conformidade com as normas brasileiras (NBR 5410, NR-10) e padrões das
            concessionárias de energia, do projeto à operação do sistema.
          </p>
        </div>

        <!-- Visão -->
        <div class="card border-2 border-accent-100 hover:border-accent-300 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-xl bg-accent-500 text-dark flex items-center justify-center text-2xl">
              🌟
            </div>
            <h3 class="text-2xl font-bold">Visão</h3>
          </div>
          <p class="text-muted leading-relaxed">
            Ser <strong class="text-dark">referência regional em energia solar</strong>
            pela qualidade dos projetos, confiabilidade das instalações e excelência
            no pós-venda, acompanhando a evolução tecnológica do setor elétrico
            e contribuindo para que a energia solar seja uma escolha
            <strong class="text-dark">segura, acessível e estrategicamente inteligente</strong>
            para pessoas e empresas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="section bg-white">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="tag">O que nos move</span>
        <h2 class="text-4xl lg:text-5xl mt-4 mb-5">Nossos <span class="text-gradient">valores</span></h2>
        <p class="text-lg text-muted leading-relaxed">
          5 princípios que guiam cada decisão, projeto e relacionamento da EcoSunPower.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {valores.map((v) => (
          <div class="card group hover:-translate-y-1 hover:border-primary-200">
            <div class="text-4xl mb-4">{v.icon}</div>
            <h3 class="font-bold text-lg mb-2 group-hover:text-primary-600 transition-colors">
              {v.titulo}
            </h3>
            <p class="text-sm text-muted leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certificações / Compliance -->
  <section class="section bg-dark text-white">
    <div class="container-wide">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm font-semibold backdrop-blur-sm">
            🏛️ Conformidade técnica
          </span>
          <h2 class="text-4xl lg:text-5xl text-white mt-5 mb-5">
            Trabalhamos com <span class="text-accent-400">normas e responsabilidade</span>
          </h2>
          <p class="text-lg text-slate-300 max-w-2xl mx-auto leading-relaxed">
            Cada projeto da EcoSunPower é executado em conformidade total com
            normas técnicas brasileiras e padrões das concessionárias.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {certificacoes.map((c) => (
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-5 text-center hover:bg-white/10 transition-all">
              <div class="text-2xl font-display font-bold text-accent-400 mb-2">{c.sigla}</div>
              <div class="text-xs text-slate-400 leading-tight">{c.nome}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-gradient-tech">
    <div class="container-narrow text-center">
      <h2 class="text-4xl lg:text-5xl mb-5">Pronto pra ser o próximo case?</h2>
      <p class="text-lg text-muted max-w-xl mx-auto mb-10">
        Agende uma conversa sem compromisso. Nossa equipe avalia
        seu caso e propõe a solução que faz sentido pra você.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/5561998805002?text=Oi!%20Vi%20a%20p%C3%A1gina%20Sobre%20da%20EcoSunPower%20e%20quero%20conhecer%20a%20empresa" target="_blank" rel="noopener" class="btn-primary text-lg">
          Falar com especialista
        </a>
        <a href="/portfolio" class="btn-secondary text-lg">
          Ver cases reais
        </a>
      </div>
    </div>
  </section>
</Layout>

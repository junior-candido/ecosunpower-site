---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contato — EcoSunPower Energia Solar"
  description="Fale com a EcoSunPower agora. WhatsApp 61 99880-5002 ou preencha o formulário pra receber seu orçamento de energia solar em até 24h."
>
  <section class="bg-gradient-hero text-white py-20 lg:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-sun opacity-50"></div>
    <div class="container-narrow relative z-10 text-center">
      <h1 class="text-4xl lg:text-6xl mb-6">Vamos conversar?</h1>
      <p class="text-lg lg:text-xl text-slate-100/90 max-w-2xl mx-auto">
        Resposta em até 24h. Visita técnica gratuita. Orçamento sem compromisso.
      </p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <!-- Formulário -->
        <div>
          <h2 class="text-3xl mb-6">Solicite seu orçamento</h2>
          <form id="contato-form" class="space-y-5">
            <div>
              <label class="block text-sm font-bold text-dark mb-2">Nome completo *</label>
              <input type="text" name="nome" required class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-100 transition" />
            </div>
            <div>
              <label class="block text-sm font-bold text-dark mb-2">WhatsApp (com DDD) *</label>
              <input type="tel" name="telefone" required placeholder="61 99999-9999" class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-100 transition" />
            </div>
            <div>
              <label class="block text-sm font-bold text-dark mb-2">Email</label>
              <input type="email" name="email" class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-100 transition" />
            </div>
            <div>
              <label class="block text-sm font-bold text-dark mb-2">Tipo de imóvel *</label>
              <select name="tipo" required class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-100 transition cursor-pointer">
                <option value="">Selecione...</option>
                <option>🏠 Residencial</option>
                <option>🏢 Comercial</option>
                <option>🌾 Rural / Agro</option>
                <option>🏭 Industrial (Grupo A)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-bold text-dark mb-2">Conta de luz mensal aprox. *</label>
              <input type="text" name="conta" required placeholder="R$ 800" class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-100 transition" />
            </div>
            <div>
              <label class="block text-sm font-bold text-dark mb-2">Mensagem (opcional)</label>
              <textarea name="mensagem" rows="3" class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl focus:border-primary-500 focus:outline-none focus:ring-4 focus:ring-primary-100 transition resize-none"></textarea>
            </div>
            <button type="submit" class="w-full btn-secondary text-lg justify-center py-4">
              Enviar pra WhatsApp
            </button>
            <p class="text-xs text-muted text-center">
              Ao enviar, você concorda com nossa <a href="/politica-de-privacidade" class="text-primary-600 hover:underline">Política de Privacidade</a>.
            </p>
          </form>
        </div>

        <!-- Info -->
        <div class="space-y-6">
          <h2 class="text-3xl mb-6">Outros canais</h2>

          <a href="https://wa.me/5561998805002" target="_blank" rel="noopener" class="block card hover:shadow-glow-primary group">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-emerald-500 text-white flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-lg group-hover:text-emerald-600 transition">WhatsApp</h3>
                <p class="text-muted text-sm">Resposta mais rápida — 2-4h em horário comercial</p>
                <p class="text-emerald-600 font-bold mt-1">+55 61 99880-5002</p>
              </div>
            </div>
          </a>

          <a href="mailto:junior@ecosunpower.eng.br" class="block card hover:shadow-glow-primary group">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-primary-500 text-white flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-lg group-hover:text-primary-600 transition">Email</h3>
                <p class="text-muted text-sm">Pra propostas técnicas, documentação</p>
                <p class="text-primary-600 font-bold mt-1">junior@ecosunpower.eng.br</p>
              </div>
            </div>
          </a>

          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-accent-500 text-dark flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-lg">Atendimento</h3>
                <p class="text-muted text-sm mt-1">
                  <strong>Brasília</strong> e região do Distrito Federal<br />
                  <strong>Goiás</strong> (Goiânia, Anápolis e cidades próximas)
                </p>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-violet-500 text-white flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-lg">CNPJ</h3>
                <p class="text-muted text-sm mt-1">
                  ECOSUNPOWER ENERGIA SOLAR LTDA<br />
                  CNPJ: 33.020.459/0001-06
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contato-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const msg =
      `Oi! Acabei de preencher o formulário no site da EcoSunPower:%0A%0A` +
      `*Nome:* ${data.get('nome')}%0A` +
      `*Telefone:* ${data.get('telefone')}%0A` +
      `*Email:* ${data.get('email') || 'não informado'}%0A` +
      `*Tipo:* ${data.get('tipo')}%0A` +
      `*Conta de luz:* ${data.get('conta')}%0A%0A` +
      `*Mensagem:* ${data.get('mensagem') || 'sem mensagem adicional'}`;

    window.open(`https://wa.me/5561998805002?text=${msg}`, '_blank');
  });
</script>

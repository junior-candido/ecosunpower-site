---
// Comparativo — tema dark. Mercado Livre trocado por Projeto Elétrico.
const features = [
  { label: 'Bateria / BESS', us: true, them: 'raramente', detail: 'Maioria não tem qualificação técnica' },
  { label: 'Grid Zero (autoconsumo total)', us: true, them: false, detail: 'Configuração avançada que poucos sabem' },
  { label: 'Sistema híbrido completo', us: true, them: false, detail: 'Solar + bateria + rede com automação' },
  { label: 'Projeto elétrico por norma', us: true, them: 'raramente', detail: 'Planta, circuitos e quadro pela NBR 5410' },
  { label: 'Aquecimento / Bomba de Calor', us: true, them: false, detail: 'Piscina aquecida, dimensionada de verdade' },
  { label: 'Engenharia 100% própria', us: true, them: 'terceiriza', detail: 'Projeto, ART e instalação sob nosso comando' },
  { label: 'Anos de experiência', us: '10 anos', them: '2-3 anos', detail: 'Empresas novas dominam o mercado' },
  { label: 'Projetos entregues', us: '600+', them: 'dezenas', detail: 'Volume e variedade contam' },
];
---

<section class="py-16 lg:py-24 bg-navy-800 relative overflow-hidden">
  <div class="container-wide relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="inline-flex items-center gap-2.5 font-mono text-xs tracking-[0.16em] uppercase text-accent-500">
        <span class="w-5 h-px bg-accent-500"></span> Sem rodeios <span class="w-5 h-px bg-accent-500"></span>
      </span>
      <h2 class="text-3xl lg:text-5xl font-display font-bold text-ink mt-4 mb-4 text-balance">
        Por que somos uma <span class="bg-gradient-to-r from-primary-400 to-green-500 bg-clip-text text-transparent">empresa premium</span>
      </h2>
      <p class="text-lg text-ink-mut leading-relaxed">
        Comparação honesta com a média do mercado em Brasília e Goiás.
        Sem citar nomes — só o que importa: o que está incluso na nossa entrega.
      </p>
    </div>

    <div class="max-w-5xl mx-auto bg-navy-700 rounded-3xl border border-navy-line overflow-hidden shadow-2xl">
      <div class="grid grid-cols-12 gap-4 p-5 border-b border-navy-line" style="background:rgba(28,169,224,.08)">
        <div class="col-span-6 md:col-span-7 font-bold text-ink">Recurso técnico</div>
        <div class="col-span-3 md:col-span-2 text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary-500 text-white rounded-full text-xs font-bold uppercase tracking-wider">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-400 animate-pulse"></span> EcoSunPower
          </div>
        </div>
        <div class="col-span-3 md:col-span-3 text-center text-sm font-semibold text-ink-mut2">Concorrente típico</div>
      </div>

      {features.map((f, i) => (
        <div class={`grid grid-cols-12 gap-4 p-5 items-center hover:bg-navy-600/40 transition-colors ${i !== features.length - 1 ? 'border-b border-navy-line' : ''}`}>
          <div class="col-span-6 md:col-span-7">
            <div class="font-semibold text-ink">{f.label}</div>
            <div class="text-xs text-ink-mut2 mt-0.5 hidden md:block">{f.detail}</div>
          </div>
          <div class="col-span-3 md:col-span-2 text-center">
            {typeof f.us === 'boolean' ? (
              <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-primary-500 text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
            ) : (
              <div class="inline-flex items-center justify-center px-3 py-1.5 rounded-full bg-primary-500 text-white text-sm font-bold">{f.us}</div>
            )}
          </div>
          <div class="col-span-3 md:col-span-3 text-center">
            {f.them === false ? (
              <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-navy-600 text-ink-mut2 mx-auto">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </div>
            ) : f.them === true ? (
              <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-green-500/15 text-green-500 mx-auto">✓</div>
            ) : (
              <div class="inline-flex items-center justify-center px-3 py-1.5 rounded-full bg-navy-600 text-ink-mut text-xs font-medium">{f.them}</div>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-11">
      <p class="text-ink-mut mb-5">Quer saber se nossa solução é pra você?</p>
      <a href="https://wa.me/5561998805002?text=Oi!%20Vi%20a%20compara%C3%A7%C3%A3o%20no%20site%20e%20quero%20conhecer%20a%20EcoSunPower" target="_blank" rel="noopener" class="btn-primary text-base">
        Conversar com especialista
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

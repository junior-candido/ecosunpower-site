---
const features = [
  { label: 'Bateria / BESS instalado', us: true, them: 'raramente', detail: 'Maioria não tem qualificação técnica' },
  { label: 'Grid Zero (autoconsumo total)', us: true, them: false, detail: 'Configuração avançada que poucos sabem' },
  { label: 'Sistema híbrido completo', us: true, them: false, detail: 'Solar + bateria + rede com automação' },
  { label: 'Grupo A (média tensão)', us: true, them: 'pequenos não fazem', detail: 'Indústria precisa de engenharia robusta' },
  { label: 'Engenharia 100% própria', us: true, them: 'terceiriza', detail: 'Projeto, ART e instalação sob nosso comando' },
  { label: 'Mercado Livre de Energia', us: true, them: false, detail: 'Migração estratégica pra empresas' },
  { label: 'Anos de experiência', us: '10 anos', them: '2-3 anos', detail: 'Empresas novas dominam o mercado' },
  { label: 'Projetos entregues', us: '600+', them: 'dezenas', detail: 'Volume e variedade contam' },
];
---

<section class="section bg-white relative overflow-hidden">
  <!-- Background subtle -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary-50/50 to-transparent pointer-events-none"></div>

  <div class="container-wide relative z-10">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="tag-accent">Sem rodeios</span>
      <h2 class="text-4xl lg:text-5xl mt-4 mb-5">
        Por que somos uma <span class="text-gradient">empresa premium</span>
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        Comparação honesta com a média do mercado de energia solar em Brasília.
        Sem mencionar nomes — só o que importa: o que está incluso na nossa entrega.
      </p>
    </div>

    <!-- Tabela -->
    <div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-card border border-slate-100 overflow-hidden">
      <!-- Header da tabela -->
      <div class="grid grid-cols-12 gap-4 p-5 bg-gradient-to-r from-primary-50 to-accent-50 border-b border-slate-100">
        <div class="col-span-6 md:col-span-7 font-bold text-dark">Recurso técnico</div>
        <div class="col-span-3 md:col-span-2 text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary-500 text-white rounded-full text-xs font-bold uppercase tracking-wider shadow-glow-primary">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-400 animate-pulse"></span>
            EcoSunPower
          </div>
        </div>
        <div class="col-span-3 md:col-span-3 text-center text-sm font-semibold text-muted">
          Concorrente típico
        </div>
      </div>

      <!-- Linhas -->
      {features.map((f, i) => (
        <div class={`grid grid-cols-12 gap-4 p-5 items-center hover:bg-primary-50/30 transition-colors ${i !== features.length - 1 ? 'border-b border-slate-100' : ''}`}>
          <div class="col-span-6 md:col-span-7">
            <div class="font-semibold text-dark">{f.label}</div>
            <div class="text-xs text-muted mt-0.5 hidden md:block">{f.detail}</div>
          </div>
          <div class="col-span-3 md:col-span-2 text-center">
            {typeof f.us === 'boolean' ? (
              <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-primary-500 text-white shadow-glow-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
            ) : (
              <div class="inline-flex items-center justify-center px-3 py-1.5 rounded-full bg-primary-500 text-white text-sm font-bold shadow-glow-primary">
                {f.us}
              </div>
            )}
          </div>
          <div class="col-span-3 md:col-span-3 text-center">
            {f.them === false ? (
              <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-slate-100 text-slate-400 mx-auto">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </div>
            ) : f.them === true ? (
              <div class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-emerald-100 text-emerald-600 mx-auto">
                ✓
              </div>
            ) : (
              <div class="inline-flex items-center justify-center px-3 py-1.5 rounded-full bg-slate-100 text-muted text-xs font-medium">
                {f.them}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA after table -->
    <div class="text-center mt-12">
      <p class="text-muted mb-5">Quer saber se nossa solução é pra você?</p>
      <a
        href="https://wa.me/5561998805002?text=Oi!%20Vi%20a%20compara%C3%A7%C3%A3o%20no%20site%20e%20quero%20conhecer%20a%20EcoSunPower"
        target="_blank"
        rel="noopener"
        class="btn-primary text-lg"
      >
        Conversar com especialista
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

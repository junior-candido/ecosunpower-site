---
// Serviços repaginado (tema dark calc): mosaico bento — a elétrica completa.
// Mercado Livre removido (ainda não atua); Bomba de Calor e Projeto Elétrico adicionados.
const wa = (txt: string) => `https://wa.me/5561998805002?text=Oi!%20${encodeURIComponent(txt)}`;
---

<section id="servicos" class="relative bg-navy py-16 lg:py-24 border-t border-navy-line">
  <div class="container-wide">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="inline-flex items-center gap-2.5 font-mono text-xs tracking-[0.16em] uppercase text-primary-400">
        <span class="w-5 h-px bg-primary-400"></span> O que a gente faz <span class="w-5 h-px bg-primary-400"></span>
      </span>
      <h2 class="text-3xl lg:text-5xl font-display font-bold text-ink mt-4 mb-3 text-balance">
        Tudo de <span class="text-primary-400">elétrica</span>, num lugar só
      </h2>
      <p class="text-lg text-ink-mut leading-relaxed">
        Da geração de energia à última tomada — com engenharia por trás de cada projeto.
      </p>
    </div>

    <!-- Bento -->
    <div class="grid grid-cols-2 lg:grid-cols-4 auto-rows-[130px] gap-3.5">
      <!-- Featured: Solar -->
      <a href={wa('Quero energia solar')} target="_blank" rel="noopener"
         class="col-span-2 row-span-2 group flex flex-col justify-end rounded-2xl p-6 border border-primary-600 transition-all hover:-translate-y-1"
         style="background:linear-gradient(158deg,rgba(28,169,224,.18),#132139)">
        <div class="text-4xl mb-auto">☀️</div>
        <h3 class="text-2xl font-display font-bold text-ink">Energia solar</h3>
        <p class="text-ink-mut text-sm mt-1.5 max-w-sm leading-relaxed">On-grid, off-grid e híbrido. Reduz a conta em até 95%, com dimensionamento de verdade.</p>
        <span class="btn-primary mt-4 w-fit text-sm py-2.5 px-5">Calcular meu sistema</span>
      </a>

      <a href={wa('Quero saber sobre bateria BESS')} target="_blank" rel="noopener"
         class="relative group flex flex-col justify-between rounded-2xl p-5 border transition-all hover:-translate-y-1"
         style="background:linear-gradient(158deg,rgba(245,184,46,.14),#132139);border-color:rgba(245,184,46,.35)">
        <span class="absolute top-3.5 right-3.5 font-mono text-[9.5px] font-bold text-navy bg-green-500 px-1.5 py-0.5 rounded">novo</span>
        <div class="text-2xl">🔋</div>
        <div><h3 class="font-bold text-ink text-[15px]">Bateria &amp; BESS</h3><p class="text-ink-mut text-xs mt-1 leading-snug">Energia 24h. Pioneiros no mercado.</p></div>
      </a>

      <a href={wa('Quero um projeto elétrico')} target="_blank" rel="noopener"
         class="group flex flex-col justify-between rounded-2xl p-5 border border-navy-line bg-navy-600 transition-all hover:-translate-y-1 hover:border-navy-line2">
        <div class="text-2xl">⚡</div>
        <div><h3 class="font-bold text-ink text-[15px]">Projeto elétrico</h3><p class="text-ink-mut text-xs mt-1 leading-snug">Planta e circuitos por norma.</p></div>
      </a>

      <a href={wa('Quero aquecer minha piscina')} target="_blank" rel="noopener"
         class="relative group flex flex-col justify-between rounded-2xl p-5 border transition-all hover:-translate-y-1"
         style="background:linear-gradient(158deg,rgba(245,184,46,.14),#132139);border-color:rgba(245,184,46,.35)">
        <span class="absolute top-3.5 right-3.5 font-mono text-[9.5px] font-bold text-navy bg-green-500 px-1.5 py-0.5 rounded">novo</span>
        <div class="text-2xl">♨️</div>
        <div><h3 class="font-bold text-ink text-[15px]">Bomba de Calor</h3><p class="text-ink-mut text-xs mt-1 leading-snug">Aquecimento de piscina.</p></div>
      </a>

      <a href={wa('Quero um carregador para carro elétrico')} target="_blank" rel="noopener"
         class="group flex flex-col justify-between rounded-2xl p-5 border border-navy-line bg-navy-600 transition-all hover:-translate-y-1 hover:border-navy-line2">
        <div class="text-2xl">🔌</div>
        <div><h3 class="font-bold text-ink text-[15px]">Carregador VE</h3><p class="text-ink-mut text-xs mt-1 leading-snug">Wallbox ao DC fast.</p></div>
      </a>

      <a href={wa('Quero manutenção do meu sistema')} target="_blank" rel="noopener"
         class="group flex flex-col justify-between rounded-2xl p-5 border border-navy-line bg-navy-600 transition-all hover:-translate-y-1 hover:border-navy-line2">
        <div class="text-2xl">🛠️</div>
        <div><h3 class="font-bold text-ink text-[15px]">Manutenção</h3><p class="text-ink-mut text-xs mt-1 leading-snug">Do nosso ou de outros.</p></div>
      </a>
    </div>

    <div class="text-center mt-11">
      <a href={wa('Quero conhecer todos os serviços da EcoSunPower')} target="_blank" rel="noopener" class="btn-primary">
        Quero falar com especialista
      </a>
    </div>
  </div>
</section>

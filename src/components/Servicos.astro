---
const servicos = [
  {
    title: 'Solar Residencial',
    desc: 'Sistemas pra casas, sítios e chácaras. Reduza sua conta em até 95% com projeto sob medida.',
    cta: 'Quero pra minha casa',
    color: 'primary',
    image: '/servico-residencial.jpg',
  },
  {
    title: 'Solar Comercial',
    desc: 'Pra lojas, escritórios, restaurantes e franquias. ROI rápido + previsibilidade de custos.',
    cta: 'Quero pro meu negócio',
    color: 'accent',
    image: '/servico-comercial.jpg',
  },
  {
    title: 'Solar + Bateria',
    desc: 'Independência total da rede. Energia 24h, mesmo se faltar luz. Sistema premium.',
    cta: 'Quero com bateria',
    color: 'primary',
    image: '/servico-bateria.jpg',
  },
];
---

<section id="servicos" class="section bg-white">
  <div class="container-wide">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="tag-accent">Nossos serviços</span>
      <h2 class="text-4xl lg:text-5xl mt-4 mb-5">
        Soluções para <span class="text-gradient">cada perfil</span>
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        Da casa de 3 quartos à indústria com demanda de 500 kWp.
        Projeto técnico personalizado pra cada cliente.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-6">
      {servicos.map((s) => (
        <div class="card group flex flex-col overflow-hidden p-0">
          <!-- Image placeholder com gradient -->
          <div class={`h-48 ${s.color === 'primary' ? 'bg-gradient-hero' : 'bg-gradient-to-br from-accent-400 to-accent-600'} relative overflow-hidden`}>
            <div class="absolute inset-0 flex items-center justify-center text-7xl opacity-90 group-hover:scale-110 transition-transform">
              {s.color === 'primary' ? '🌞' : '⚡'}
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          </div>

          <!-- Content -->
          <div class="p-6 flex-1 flex flex-col">
            <h3 class="text-2xl font-bold mb-3 group-hover:text-primary-600 transition-colors">
              {s.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed mb-6 flex-1">{s.desc}</p>

            <a
              href={`https://wa.me/5561998805002?text=Oi!%20${encodeURIComponent(s.cta)}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-bold text-sm group/cta"
            >
              {s.cta}
              <svg class="w-4 h-4 group-hover/cta:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <a
        href="https://wa.me/5561998805002?text=Oi!%20Quero%20conhecer%20todos%20os%20servi%C3%A7os%20da%20EcoSunPower"
        target="_blank"
        rel="noopener"
        class="btn-secondary"
      >
        Quero falar com especialista
      </a>
    </div>
  </div>
</section>

---
// Slider COM vs SEM solar — visual interativo de persuasão
---

<section class="section bg-gradient-tech">
  <div class="container-wide">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="tag">Visualização interativa</span>
      <h2 class="text-4xl lg:text-5xl mt-4 mb-5">
        Sua vida em <span class="text-gradient">25 anos</span>
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        Arraste o controle pra ver a diferença real entre continuar pagando a distribuidora
        ou investir uma vez em energia solar.
      </p>
    </div>

    <!-- Slider container -->
    <div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-card p-8 lg:p-12">
      <!-- Conta atual input -->
      <div class="mb-10 text-center">
        <label class="block text-sm font-semibold text-muted mb-3 uppercase tracking-wider">
          Sua conta de luz mensal
        </label>
        <div class="inline-flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-full px-6 py-3">
          <span class="text-2xl font-bold text-muted">R$</span>
          <input
            type="number"
            id="conta-mensal"
            value="800"
            min="100"
            max="50000"
            class="w-32 text-3xl font-bold text-dark bg-transparent border-none outline-none text-center"
          />
          <span class="text-sm text-muted">/mês</span>
        </div>
      </div>

      <!-- Year slider -->
      <div class="mb-10">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm font-semibold text-muted">Anos no futuro:</span>
          <span class="text-3xl font-display font-bold text-primary-600" id="ano-display">10 anos</span>
        </div>
        <input
          type="range"
          id="ano-slider"
          min="1"
          max="25"
          value="10"
          class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
        />
        <div class="flex justify-between text-xs text-muted mt-2">
          <span>1 ano</span>
          <span>10 anos</span>
          <span>25 anos</span>
        </div>
      </div>

      <!-- Comparativo lado a lado -->
      <div class="grid md:grid-cols-2 gap-6">
        <!-- SEM solar -->
        <div class="bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-200 rounded-2xl p-6 text-center">
          <div class="inline-block px-3 py-1 bg-red-500 text-white text-xs font-bold rounded-full mb-3 uppercase tracking-wider">
            Sem solar
          </div>
          <div class="text-4xl mb-2">😩</div>
          <div class="text-sm text-muted mb-2">Você terá pago à distribuidora:</div>
          <div class="text-3xl lg:text-4xl font-display font-bold text-red-600" id="sem-solar-valor">
            R$ 0
          </div>
          <div class="text-xs text-muted mt-3" id="sem-solar-detalhe">
            Considerando reajuste anual médio de 7%
          </div>
        </div>

        <!-- COM solar -->
        <div class="bg-gradient-to-br from-primary-50 to-emerald-50 border-2 border-primary-300 rounded-2xl p-6 text-center relative overflow-hidden">
          <div class="absolute -top-3 -right-3 bg-accent-500 text-dark text-xs font-bold px-3 py-1.5 rounded-full shadow-glow-accent rotate-12">
            ECONOMIA REAL
          </div>
          <div class="inline-block px-3 py-1 bg-primary-500 text-white text-xs font-bold rounded-full mb-3 uppercase tracking-wider">
            Com solar EcoSunPower
          </div>
          <div class="text-4xl mb-2">😎</div>
          <div class="text-sm text-muted mb-2">Você terá investido apenas:</div>
          <div class="text-3xl lg:text-4xl font-display font-bold text-primary-600" id="com-solar-valor">
            R$ 0
          </div>
          <div class="text-xs text-emerald-700 font-bold mt-3" id="com-solar-detalhe">
            (sistema pago em ~4 anos, depois é tudo economia)
          </div>
        </div>
      </div>

      <!-- Diferença -->
      <div class="mt-8 text-center bg-gradient-to-r from-primary-500 to-accent-500 text-white rounded-2xl p-6">
        <div class="text-sm uppercase tracking-wider opacity-90 mb-2">
          Você economiza em <span id="anos-eco">10 anos</span>:
        </div>
        <div class="text-4xl lg:text-5xl font-display font-bold mb-3" id="economia-total">
          R$ 0
        </div>
        <a
          href="https://wa.me/5561998805002?text=Oi!%20Acabei%20de%20simular%20no%20site%20e%20quero%20conhecer%20o%20sistema%20pra%20mim"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-white text-primary-700 px-6 py-3 rounded-full font-bold text-sm hover:scale-105 transition-transform"
        >
          Quero economizar agora
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const contaInput = document.getElementById('conta-mensal') as HTMLInputElement;
  const anoSlider = document.getElementById('ano-slider') as HTMLInputElement;
  const anoDisplay = document.getElementById('ano-display');
  const semValor = document.getElementById('sem-solar-valor');
  const comValor = document.getElementById('com-solar-valor');
  const economiaTotal = document.getElementById('economia-total');
  const anosEco = document.getElementById('anos-eco');

  const REAJUSTE_ANUAL = 0.07;
  const TAXA_MIN_MENSAL = 30;

  function formatBRL(value: number): string {
    return value.toLocaleString('pt-BR', {
      style: 'currency',
      currency: 'BRL',
      maximumFractionDigits: 0,
    });
  }

  function calcular() {
    const conta = parseFloat(contaInput.value) || 0;
    const anos = parseInt(anoSlider.value) || 1;

    // SEM solar: conta com reajuste anual composto
    let totalSemSolar = 0;
    let contaAtual = conta;
    for (let i = 0; i < anos; i++) {
      totalSemSolar += contaAtual * 12;
      contaAtual *= (1 + REAJUSTE_ANUAL);
    }

    // COM solar: investimento inicial (estimado em 6x conta atual = um sistema típico)
    // Após pago, só taxa mínima de R$ 30/mês
    const investimento = conta * 12; // ~12x conta = ~ROI 4-5 anos
    const totalComSolar = investimento + (TAXA_MIN_MENSAL * 12 * anos);

    // Update UI
    if (anoDisplay) anoDisplay.textContent = `${anos} ${anos === 1 ? 'ano' : 'anos'}`;
    if (anosEco) anosEco.textContent = `${anos} ${anos === 1 ? 'ano' : 'anos'}`;
    if (semValor) semValor.textContent = formatBRL(totalSemSolar);
    if (comValor) comValor.textContent = formatBRL(totalComSolar);
    if (economiaTotal) economiaTotal.textContent = formatBRL(Math.max(0, totalSemSolar - totalComSolar));
  }

  contaInput?.addEventListener('input', calcular);
  anoSlider?.addEventListener('input', calcular);

  // Initial calculation
  calcular();
</script>

<style>
  /* Slider customizado */
  input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    height: 24px;
    width: 24px;
    border-radius: 50%;
    background: #1FB8E8;
    cursor: pointer;
    box-shadow: 0 0 10px rgba(31, 184, 232, 0.5);
    border: 3px solid white;
    transition: transform 0.2s;
  }
  input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.2);
  }
  input[type="range"]::-moz-range-thumb {
    height: 24px;
    width: 24px;
    border-radius: 50%;
    background: #1FB8E8;
    cursor: pointer;
    border: 3px solid white;
  }
</style>

---
// Slider COM vs SEM solar — visual interativo (tema dark)
---

<section class="py-16 lg:py-24 bg-navy border-t border-navy-line">
  <div class="container-wide">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="inline-flex items-center gap-2.5 font-mono text-xs tracking-[0.16em] uppercase text-primary-400">
        <span class="w-5 h-px bg-primary-400"></span> Visualização interativa <span class="w-5 h-px bg-primary-400"></span>
      </span>
      <h2 class="text-3xl lg:text-5xl font-display font-bold text-ink mt-4 mb-4 text-balance">
        Sua vida em <span class="bg-gradient-to-r from-primary-400 to-green-500 bg-clip-text text-transparent">25 anos</span>
      </h2>
      <p class="text-lg text-ink-mut leading-relaxed">
        Arraste o controle pra ver a diferença real entre continuar pagando a distribuidora
        ou investir uma vez em energia solar.
      </p>
    </div>

    <div class="max-w-5xl mx-auto bg-navy-700 rounded-3xl border border-navy-line p-8 lg:p-12 shadow-2xl">
      <div class="mb-10 text-center">
        <label class="block text-sm font-semibold text-ink-mut mb-3 uppercase tracking-wider">Sua conta de luz mensal</label>
        <div class="inline-flex items-center gap-3 bg-navy-600 border border-navy-line2 rounded-full px-6 py-3">
          <span class="text-2xl font-bold text-ink-mut2">R$</span>
          <input type="number" id="conta-mensal" value="800" min="100" max="50000"
            class="w-32 text-3xl font-bold text-ink bg-transparent border-none outline-none text-center" />
          <span class="text-sm text-ink-mut2">/mês</span>
        </div>
      </div>

      <div class="mb-10">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm font-semibold text-ink-mut">Anos no futuro:</span>
          <span class="text-3xl font-display font-bold text-primary-400" id="ano-display">10 anos</span>
        </div>
        <input type="range" id="ano-slider" min="1" max="25" value="10"
          class="w-full h-2 bg-navy-600 rounded-lg appearance-none cursor-pointer accent-primary-500" />
        <div class="flex justify-between text-xs text-ink-mut2 mt-2"><span>1 ano</span><span>10 anos</span><span>25 anos</span></div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-2xl p-6 text-center border-2 border-red-500/30" style="background:linear-gradient(160deg,rgba(239,90,89,.12),#132139)">
          <div class="inline-block px-3 py-1 bg-red-500 text-white text-xs font-bold rounded-full mb-3 uppercase tracking-wider">Sem solar</div>
          <div class="text-4xl mb-2">😩</div>
          <div class="text-sm text-ink-mut mb-2">Você terá pago à distribuidora:</div>
          <div class="text-3xl lg:text-4xl font-display font-bold text-red-400" id="sem-solar-valor">R$ 0</div>
          <div class="text-xs text-ink-mut2 mt-3" id="sem-solar-detalhe">Considerando reajuste anual médio de 7%</div>
        </div>

        <div class="rounded-2xl p-6 text-center relative overflow-hidden border-2 border-primary-500/40" style="background:linear-gradient(160deg,rgba(28,169,224,.14),#132139)">
          <div class="absolute -top-3 -right-3 bg-accent-500 text-navy text-xs font-bold px-3 py-1.5 rounded-full rotate-12">ECONOMIA REAL</div>
          <div class="inline-block px-3 py-1 bg-primary-500 text-white text-xs font-bold rounded-full mb-3 uppercase tracking-wider">Com solar EcoSunPower</div>
          <div class="text-4xl mb-2">😎</div>
          <div class="text-sm text-ink-mut mb-2">Você terá investido apenas:</div>
          <div class="text-3xl lg:text-4xl font-display font-bold text-primary-400" id="com-solar-valor">R$ 0</div>
          <div class="text-xs text-green-500 font-bold mt-3" id="com-solar-detalhe">(sistema pago em ~4 anos, depois é tudo economia)</div>
        </div>
      </div>

      <div class="mt-8 text-center bg-gradient-to-r from-primary-500 to-accent-500 text-white rounded-2xl p-6">
        <div class="text-sm uppercase tracking-wider opacity-90 mb-2">Você economiza em <span id="anos-eco">10 anos</span>:</div>
        <div class="text-4xl lg:text-5xl font-display font-bold mb-3" id="economia-total">R$ 0</div>
        <a href="https://wa.me/5561998805002?text=Oi!%20Acabei%20de%20simular%20no%20site%20e%20quero%20conhecer%20o%20sistema%20pra%20mim" target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 bg-white text-primary-700 px-6 py-3 rounded-full font-bold text-sm hover:scale-105 transition-transform">
          Quero economizar agora
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const contaInput = document.getElementById('conta-mensal') as HTMLInputElement;
  const anoSlider = document.getElementById('ano-slider') as HTMLInputElement;
  const anoDisplay = document.getElementById('ano-display');
  const semValor = document.getElementById('sem-solar-valor');
  const comValor = document.getElementById('com-solar-valor');
  const economiaTotal = document.getElementById('economia-total');
  const anosEco = document.getElementById('anos-eco');

  const REAJUSTE_ANUAL = 0.07;
  const TAXA_MIN_MENSAL = 30;

  function formatBRL(value: number): string {
    return value.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 });
  }

  function calcular() {
    const conta = parseFloat(contaInput.value) || 0;
    const anos = parseInt(anoSlider.value) || 1;

    let totalSemSolar = 0;
    let contaAtual = conta;
    for (let i = 0; i < anos; i++) {
      totalSemSolar += contaAtual * 12;
      contaAtual *= (1 + REAJUSTE_ANUAL);
    }

    const investimento = conta * 12;
    const totalComSolar = investimento + (TAXA_MIN_MENSAL * 12 * anos);

    if (anoDisplay) anoDisplay.textContent = `${anos} ${anos === 1 ? 'ano' : 'anos'}`;
    if (anosEco) anosEco.textContent = `${anos} ${anos === 1 ? 'ano' : 'anos'}`;
    if (semValor) semValor.textContent = formatBRL(totalSemSolar);
    if (comValor) comValor.textContent = formatBRL(totalComSolar);
    if (economiaTotal) economiaTotal.textContent = formatBRL(Math.max(0, totalSemSolar - totalComSolar));
  }

  contaInput?.addEventListener('input', calcular);
  anoSlider?.addEventListener('input', calcular);
  calcular();
</script>

<style>
  input[type="range"] { -webkit-appearance: none; appearance: none; }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none; height: 24px; width: 24px; border-radius: 50%;
    background: #1ca9e0; cursor: pointer; box-shadow: 0 0 10px rgba(28,169,224,0.6); border: 3px solid #0b1220; transition: transform 0.2s;
  }
  input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); }
  input[type="range"]::-moz-range-thumb {
    height: 24px; width: 24px; border-radius: 50%; background: #1ca9e0; cursor: pointer; border: 3px solid #0b1220;
  }
</style>

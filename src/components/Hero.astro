---
// Hero impactante: visual bold + emocional + dados
---

<section class="relative overflow-hidden bg-gradient-hero min-h-[90vh] flex items-center pt-12 pb-20">
  <!-- Background decorations -->
  <div class="absolute inset-0 bg-gradient-sun opacity-60 pointer-events-none"></div>

  <!-- Grid de painel solar (decoração de fundo) -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <!-- Floating sun decoration -->
  <div class="absolute -top-20 -right-20 w-96 h-96 bg-accent-500/20 rounded-full blur-3xl animate-pulse-soft"></div>
  <div class="absolute bottom-10 -left-10 w-72 h-72 bg-primary-300/20 rounded-full blur-3xl"></div>

  <div class="container-wide relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <!-- Conteúdo -->
      <div class="lg:col-span-7 text-white animate-fade-in-up">
        <!-- Tag superior -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full mb-8">
          <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
          <span class="text-sm font-semibold">600+ projetos entregues em Brasília e Goiás</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-display font-bold leading-[1.05] mb-6">
          Liberte sua casa<br />
          ou empresa da<br />
          <span class="text-accent-400">conta de luz</span>.
        </h1>

        <p class="text-lg lg:text-xl text-slate-100/90 max-w-2xl leading-relaxed mb-10">
          Energia solar com <strong class="text-white">baterias</strong>, <strong class="text-white">Grid Zero</strong> e <strong class="text-white">sistemas híbridos</strong>
          — projetada por engenheiros, instalada por especialistas.
          Tecnologia premium, ROI em até 4 anos.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href="https://wa.me/5561998805002?text=Oi!%20Quero%20um%20or%C3%A7amento%20de%20energia%20solar"
            target="_blank"
            rel="noopener"
            class="btn-primary text-lg"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Quero meu orçamento
          </a>
          <a href="#diferenciais" class="btn-outline text-lg">
            Por que EcoSunPower?
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </a>
        </div>

        <!-- Stats bar -->
        <div class="grid grid-cols-3 gap-6 max-w-2xl border-t border-white/15 pt-8">
          <div>
            <div class="text-3xl lg:text-4xl font-display font-bold text-accent-400">600+</div>
            <div class="text-xs lg:text-sm text-slate-300 mt-1">Projetos entregues</div>
          </div>
          <div>
            <div class="text-3xl lg:text-4xl font-display font-bold text-accent-400">10 anos</div>
            <div class="text-xs lg:text-sm text-slate-300 mt-1">Experiência técnica</div>
          </div>
          <div>
            <div class="text-3xl lg:text-4xl font-display font-bold text-accent-400">100%</div>
            <div class="text-xs lg:text-sm text-slate-300 mt-1">Engenharia própria</div>
          </div>
        </div>
      </div>

      <!-- Visual: vídeo da logo em loop (premium) -->
      <div class="lg:col-span-5 hidden lg:flex justify-center items-center">
        <div class="relative animate-float">
          <!-- Glow -->
          <div class="absolute inset-0 bg-accent-400/30 rounded-full blur-3xl"></div>

          <!-- Vídeo da logo em loop (sem áudio, autoplay) -->
          <div class="relative bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-8 shadow-2xl">
            <video
              autoplay
              muted
              loop
              playsinline
              poster="/logo-ecosunpower-icon.png"
              class="w-72 h-72 object-contain mx-auto drop-shadow-2xl rounded-2xl"
              aria-label="Logo EcoSunPower em movimento"
            >
              <source src="/hero-logo.mp4" type="video/mp4" />
              <!-- Fallback se vídeo não carregar -->
              <img
                src="/logo-ecosunpower-icon.png"
                alt="EcoSunPower"
                class="w-72 h-72 object-contain"
              />
            </video>
          </div>

          <!-- Badges flutuantes -->
          <div class="absolute -top-4 -right-4 bg-accent-500 text-dark px-4 py-2 rounded-xl shadow-glow-accent font-bold text-sm">
            ⚡ Bateria + BESS
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white text-primary-700 px-4 py-2 rounded-xl shadow-lg font-bold text-sm">
            🌞 Grid Zero
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider bottom -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg class="w-full h-16 text-surface-alt" preserveAspectRatio="none" viewBox="0 0 1200 80" fill="currentColor">
      <path d="M0,80 L0,40 Q300,80 600,40 T1200,40 L1200,80 Z" />
    </svg>
  </div>
</section>

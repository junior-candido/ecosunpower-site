---
// Hero repaginado (tema dark calc): claim elétrica completa + card "resultado do motor"
const WA = 'https://wa.me/5561998805002?text=Oi!%20Quero%20um%20or%C3%A7amento';
---

<section class="relative overflow-hidden bg-navy pt-14 pb-16 lg:pt-20 lg:pb-20">
  <!-- Brilho de energia (aura) -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background:
      radial-gradient(52% 48% at 22% -6%, rgba(28,169,224,.30), transparent 60%),
      radial-gradient(40% 40% at 92% 14%, rgba(46,204,155,.18), transparent 60%),
      radial-gradient(38% 40% at 68% 118%, rgba(245,184,46,.08), transparent 60%);"
  >
  </div>

  <div class="container-wide relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-14 items-center">
      <!-- Conteúdo -->
      <div class="lg:col-span-7 animate-fade-in-up">
        <span class="inline-flex items-center gap-2.5 font-mono text-xs tracking-[0.16em] uppercase text-primary-400">
          <span class="w-5 h-px bg-primary-400"></span>
          Engenharia elétrica · Brasília &amp; Goiás
        </span>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold leading-[1.03] tracking-tight text-ink mt-5 mb-5 text-balance">
          A <span class="bg-gradient-to-r from-primary-400 to-green-500 bg-clip-text text-transparent">elétrica completa</span>
          da sua casa ou empresa — do sol à última tomada.
        </h1>

        <p class="text-lg lg:text-xl text-ink-mut leading-relaxed max-w-xl mb-8">
          Solar é o nosso carro-chefe, mas a gente resolve a energia inteira:
          <strong class="text-ink font-semibold">bateria, projeto elétrico, aquecimento e carregador</strong>.
          Com projeto assinado e gente que atende você pelo nome.
        </p>

        <div class="flex flex-col sm:flex-row gap-3.5">
          <a href="/calculadora" class="btn-primary text-base">
            Calcular minha economia
          </a>
          <a href={WA} target="_blank" rel="noopener"
             class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full border border-navy-line2 text-ink font-semibold text-base hover:border-primary-500 hover:text-white transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Falar no WhatsApp
          </a>
        </div>

        <div class="flex items-center gap-4 mt-7 text-sm text-ink-mut">
          <span><strong class="text-ink">600+ projetos</strong> entregues</span>
          <span class="w-px h-4 bg-navy-line2"></span>
          <span><strong class="text-ink">Projeto assinado por RT · CFT</strong></span>
        </div>
      </div>

      <!-- Card "resultado do motor" (assinatura) -->
      <div class="lg:col-span-5">
        <div class="rounded-2xl overflow-hidden border border-navy-line2 shadow-2xl"
             style="background:linear-gradient(162deg,#132139,#0e1728)">
          <div class="flex items-center justify-between px-4 py-3.5 border-b border-navy-line" style="background:rgba(28,169,224,.07)">
            <span class="font-mono text-xs tracking-wider text-primary-400">MOTOR · resultado</span>
            <span class="w-2 h-2 rounded-full bg-green-500" style="box-shadow:0 0 10px #2ecc9b"></span>
          </div>
          <div class="flex items-baseline justify-between px-4 py-3 border-b border-navy-line/60">
            <span class="text-sm text-ink-mut">Sistema</span>
            <span class="font-mono text-base font-bold text-ink tabular-nums">8,2 <span class="text-xs text-ink-mut2 font-normal">kWp</span></span>
          </div>
          <div class="flex items-baseline justify-between px-4 py-3 border-b border-navy-line/60">
            <span class="text-sm text-ink-mut">Geração estimada</span>
            <span class="font-mono text-base font-bold text-ink tabular-nums">1.180 <span class="text-xs text-ink-mut2 font-normal">kWh/mês</span></span>
          </div>
          <div class="flex items-baseline justify-between px-4 py-3 border-b border-navy-line/60">
            <span class="text-sm text-ink-mut">Economia</span>
            <span class="font-mono text-base font-bold text-green-500 tabular-nums">R$ 1.140<span class="text-xs text-ink-mut2 font-normal">/mês</span></span>
          </div>
          <div class="flex items-baseline justify-between px-4 py-3 border-b border-navy-line/60">
            <span class="text-sm text-ink-mut">Cabo · disjuntor</span>
            <span class="font-mono text-base font-bold text-ink tabular-nums">6 mm² · 20 A 📐</span>
          </div>
          <div class="flex items-center gap-2.5 px-4 py-3 text-xs text-green-500">
            <span class="font-mono text-[10px] font-bold text-navy px-1.5 py-0.5 rounded bg-green-500">✓ NBR 5410</span>
            Dimensionado por norma, não chutado
          </div>
        </div>
        <div class="font-mono text-[10.5px] text-ink-mut2 text-right mt-2">simulação ilustrativa</div>
      </div>
    </div>
  </div>
</section>

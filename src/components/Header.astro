---
// Cabeçalho — tema dark (cara da calculadora). Logo sempre visível.
const navLinks = [
  { href: '/sobre', label: 'Sobre' },
  { href: '/#servicos', label: 'Serviços' },
  { href: '/portfolio', label: 'Cases' },
  { href: '/blog', label: 'Blog' },
  { href: '/cotacao', label: 'Cotação' },
  { href: '/contato', label: 'Contato' },
  { href: '/trabalhe-conosco', label: 'Trabalhe Conosco' },
];

const ferramentas = [
  { href: '/calculadora', label: '🧮 Calculadora de dimensionamento' },
  { href: '/simulador', label: '📊 Simulador de medidores' },
  { href: '/ferramentas/simulador-piscina.html', label: '🏊 Simulador de piscina' },
  { href: '/ferramentas/recarga-condominio.html', label: '🏢 Recarga em condomínio' },
  { href: '/ferramentas/manual-projetos-eletricos.html', label: '📗 Manual de projetos elétricos' },
  { href: '/ferramentas/boas-praticas-instalacao.html', label: '📘 Boas práticas de instalação' },
  { href: '/tutorial', label: '📶 Tutorial Wi-Fi do inversor' },
];

const PAINEL_URL = 'https://propostas.ecosunpower.eng.br/dashboard';
---

<header class="sticky top-0 z-50 bg-navy/85 backdrop-blur-md border-b border-navy-line">
  <div class="container-wide flex items-center justify-between h-20 md:h-24">
    <!-- Logo (sempre visível) -->
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/logo-ecosun-ecossistema.png"
        alt="EcoSunPower Energia Solar"
        class="h-12 md:h-16 w-auto transition-transform group-hover:scale-105"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-6">
      {navLinks.slice(0, 2).map((link) => (
        <a href={link.href} class="text-sm font-semibold text-ink-mut hover:text-ink transition-colors whitespace-nowrap">
          {link.label}
        </a>
      ))}

      <!-- Dropdown Ferramentas -->
      <div class="relative group">
        <button type="button" class="text-sm font-semibold text-ink-mut group-hover:text-ink transition-colors whitespace-nowrap inline-flex items-center gap-1 py-2">
          Ferramentas <span class="text-xs">▾</span>
        </button>
        <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 hidden group-hover:block group-focus-within:block">
          <div class="bg-navy-700 rounded-xl border border-navy-line shadow-2xl py-2 min-w-[230px]">
            {ferramentas.map((f) => (
              <a href={f.href} class="block px-4 py-2.5 text-sm font-semibold text-ink-mut hover:bg-navy-600 hover:text-white transition whitespace-nowrap">
                {f.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      {navLinks.slice(2).map((link) => (
        <a href={link.href} class="text-sm font-semibold text-ink-mut hover:text-ink transition-colors whitespace-nowrap">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Painel + CTA WhatsApp -->
    <div class="hidden lg:flex items-center gap-2">
      <a href={PAINEL_URL}
        class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full border border-navy-line2 text-sm font-semibold text-ink-mut hover:border-primary-500 hover:text-white transition whitespace-nowrap">
        🔒 Painel
      </a>
      <a href="https://wa.me/5561998805002" target="_blank" rel="noopener" class="btn-primary py-2.5 px-5 text-sm whitespace-nowrap">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-toggle" class="lg:hidden p-2 text-ink hover:text-primary-400 transition" aria-label="Abrir menu">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu (rolável) -->
  <nav id="mobile-menu" class="lg:hidden hidden bg-navy border-t border-navy-line max-h-[calc(100dvh-5rem)] overflow-y-auto overscroll-contain">
    <div class="container-wide py-4 flex flex-col gap-2">
      {navLinks.map((link) => (
        <a href={link.href} class="py-3 px-4 rounded-lg text-base font-semibold text-ink-mut hover:bg-navy-700 hover:text-white transition">
          {link.label}
        </a>
      ))}
      <div class="border-t border-navy-line my-1"></div>
      {ferramentas.map((f) => (
        <a href={f.href} class="py-3 px-4 rounded-lg text-base font-semibold text-ink-mut hover:bg-navy-700 hover:text-white transition">
          {f.label}
        </a>
      ))}
      <a href={PAINEL_URL} class="py-3 px-4 rounded-lg text-base font-semibold text-ink-mut hover:bg-navy-700 hover:text-white transition">
        🔒 Painel
      </a>
      <a href="https://wa.me/5561998805002" target="_blank" rel="noopener" class="mt-2 btn-primary">
        Falar no WhatsApp
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

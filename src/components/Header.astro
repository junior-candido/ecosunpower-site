---
const navLinks = [
  { href: '/#servicos', label: 'Serviços' },
  { href: '/#diferenciais', label: 'Por que EcoSunPower' },
  { href: '/portfolio', label: 'Cases' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
  <div class="container-wide flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/logo-ecosunpower.png"
        alt="EcoSunPower Energia Solar"
        class="h-12 w-auto transition-transform group-hover:scale-105"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-semibold text-dark-soft hover:text-primary-600 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA Desktop -->
    <a
      href="https://wa.me/5561998805002"
      target="_blank"
      rel="noopener"
      class="hidden lg:inline-flex btn-primary py-2.5 px-5 text-sm"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      WhatsApp
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden p-2 text-dark hover:text-primary-600 transition"
      aria-label="Abrir menu"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="lg:hidden hidden bg-white border-t border-slate-100">
    <div class="container-wide py-4 flex flex-col gap-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="py-3 px-4 rounded-lg text-base font-semibold text-dark-soft hover:bg-primary-50 hover:text-primary-700 transition"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/5561998805002"
        target="_blank"
        rel="noopener"
        class="mt-2 btn-primary"
      >
        Falar no WhatsApp
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

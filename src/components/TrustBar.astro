---

<section class="bg-gradient-tech py-20 lg:py-24 border-y border-slate-200">
  <div class="container-wide">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="tag-accent">Tecnologia premium</span>
      <h2 class="text-3xl lg:text-5xl mt-4 mb-5">
        Trabalhamos só com <span class="text-gradient">o melhor do mercado</span>
      </h2>
      <p class="text-base lg:text-lg text-muted leading-relaxed">
        Fornecedores Tier 1 com tecnologia de ponta — TOPCon, N-Type, Half-cell, Bifacial,
        otimizadores e híbridos. <strong>Clica em qualquer marca</strong> pra saber mais.
      </p>
    </div>

    <!-- Categorias -->
    <div class="space-y-8 max-w-6xl mx-auto">
      {categorias.map((cat) => (
        <div>
          <div class="flex items-center gap-3 mb-4 px-2">
            <span class="text-2xl">{cat.icon}</span>
            <h3 class="font-display font-bold text-dark text-lg">{cat.titulo}</h3>
            <div class="flex-1 h-px bg-slate-200"></div>
          </div>

          <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-7 gap-2">
            {cat.marcas.map((m, mIdx) => (
              <button
                type="button"
                data-marca={`${cat.titulo}::${m.nome}`}
                class="marca-btn group relative bg-white hover:bg-primary-50 border border-slate-200 hover:border-primary-400 rounded-lg px-3 py-2.5 text-center transition-all hover:-translate-y-0.5 hover:shadow-card flex items-center justify-center"
              >
                <div class="font-bold text-xs text-dark group-hover:text-primary-700 transition-colors leading-tight">
                  {m.nome}
                </div>
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom: tecnologias clicáveis -->
    <div class="text-center mt-14">
      <p class="text-xs uppercase tracking-widest text-muted font-bold mb-4">
        Tecnologias premium em todos os projetos · <span class="text-primary-600">Clica pra entender</span>
      </p>
      <div class="inline-flex flex-wrap items-center justify-center gap-2 px-2 max-w-4xl">
        {tecnologias.map((t) => (
          <button type="button" data-tech={t.nome} class="tech-badge cursor-pointer">
            {t.icon} {t.nome}
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .tech-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.1rem;
    background-color: #0B5A87 !important;
    color: #ffffff !important;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: 0 4px 12px rgba(11, 90, 135, 0.25);
    transition: all 0.2s;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .tech-badge:hover {
    background-color: #073E5C !important;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(11, 90, 135, 0.4);
  }
</style>

<!-- MODAL DE INFORMAÇÃO DA MARCA -->
<div id="marca-modal" class="marca-modal-bg fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-dark/60 backdrop-blur-sm transition-opacity duration-200" data-state="closed">
  <div id="marca-modal-content" class="marca-modal-card bg-white rounded-3xl max-w-lg w-full max-h-[85vh] overflow-y-auto shadow-2xl transition-all duration-200">
    <!-- Conteúdo injetado via JS -->
  </div>
</div>

<style>
  .marca-modal-bg[data-state="closed"] {
    opacity: 0;
    pointer-events: none;
  }
  .marca-modal-bg[data-state="open"] {
    opacity: 1;
    pointer-events: auto;
  }
  .marca-modal-bg[data-state="closed"] .marca-modal-card {
    transform: translateY(20px) scale(0.95);
    opacity: 0;
  }
  .marca-modal-bg[data-state="open"] .marca-modal-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
</style>

<script define:vars={{ categoriasData: categorias, tecnologiasData: tecnologias }}>
  const modal = document.getElementById('marca-modal');
  const modalContent = document.getElementById('marca-modal-content');

  // Mapa rápido pra encontrar marca por chave
  const marcasMap = {};
  categoriasData.forEach((cat) => {
    cat.marcas.forEach((m) => {
      marcasMap[`${cat.titulo}::${m.nome}`] = { ...m, categoria: cat.titulo, icon: cat.icon };
    });
  });

  // Mapa de tecnologias
  const techMap = {};
  tecnologiasData.forEach((t) => {
    techMap[t.nome] = t;
  });

  // Renderiza conteúdo do modal
  function renderModal(marca) {
    const techHtml = marca.tecnologias && marca.tecnologias.length
      ? `<div class="mt-5">
           <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-2">Tecnologias destaque</h4>
           <div class="flex flex-wrap gap-2">
             ${marca.tecnologias.map((t) => `<span class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-semibold">${t}</span>`).join('')}
           </div>
         </div>`
      : '';

    const usaHtml = marca.ecosunUsa
      ? `<div class="mt-5 p-4 bg-accent-50 border-2 border-accent-200 rounded-xl">
           <div class="flex items-start gap-3">
             <span class="text-2xl">⚡</span>
             <div>
               <h4 class="text-sm font-bold text-dark mb-1">Como a EcoSunPower usa</h4>
               <p class="text-sm text-muted leading-relaxed">${marca.ecosunUsa}</p>
             </div>
           </div>
         </div>`
      : '';

    modalContent.innerHTML = `
      <div class="relative">
        <!-- Header com gradient -->
        <div class="bg-gradient-hero p-6 rounded-t-3xl text-white relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-40 h-40 bg-accent-400/30 rounded-full blur-3xl"></div>
          <button type="button" class="modal-close-btn absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center transition-colors z-10 cursor-pointer" aria-label="Fechar">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <div class="relative">
            <div class="text-xs text-slate-200/80 mb-2 uppercase tracking-wider font-semibold">
              ${marca.icon} ${marca.categoria}
            </div>
            <h3 class="text-3xl font-display font-bold">${marca.nome}</h3>
            <div class="text-sm text-slate-100/90 mt-2">${marca.origem}</div>
          </div>
        </div>

        <!-- Body -->
        <div class="p-6">
          <p class="text-base text-dark font-semibold leading-snug">${marca.destaque}</p>

          <div class="mt-5">
            <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-3">Por que é referência</h4>
            <ul class="space-y-2">
              ${marca.pontos.map((p) => `
                <li class="flex items-start gap-2 text-sm text-dark-soft">
                  <span class="text-primary-500 mt-0.5">✓</span>
                  <span>${p}</span>
                </li>
              `).join('')}
            </ul>
          </div>

          ${techHtml}
          ${usaHtml}

          <a href="https://wa.me/5561998805002?text=${encodeURIComponent(`Oi! Quero saber mais sobre sistemas com ${marca.nome}`)}" target="_blank" rel="noopener" class="mt-6 w-full inline-flex items-center justify-center gap-2 bg-primary-500 hover:bg-primary-600 text-white font-bold text-sm px-5 py-3 rounded-full transition-colors">
            Quero um sistema com ${marca.nome}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    `;

  }

  function renderTechModal(tech) {
    modalContent.innerHTML = `
      <div class="relative">
        <div class="bg-gradient-hero p-6 rounded-t-3xl text-white relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-40 h-40 bg-accent-400/30 rounded-full blur-3xl"></div>
          <button type="button" class="modal-close-btn absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center transition-colors z-10 cursor-pointer" aria-label="Fechar">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <div class="relative">
            <div class="text-xs text-slate-200/80 mb-2 uppercase tracking-wider font-semibold">
              🔬 Tecnologia
            </div>
            <h3 class="text-3xl font-display font-bold">${tech.icon} ${tech.nome}</h3>
          </div>
        </div>

        <div class="p-6">
          <div>
            <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-2">O que é</h4>
            <p class="text-sm text-dark-soft leading-relaxed">${tech.oQueE}</p>
          </div>

          <div class="mt-5">
            <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-3">Vantagens reais</h4>
            <ul class="space-y-2">
              ${tech.vantagens.map((v) => `
                <li class="flex items-start gap-2 text-sm text-dark-soft">
                  <span class="text-primary-500 mt-0.5">✓</span>
                  <span>${v}</span>
                </li>
              `).join('')}
            </ul>
          </div>

          <div class="mt-5 p-4 bg-accent-50 border-2 border-accent-200 rounded-xl">
            <div class="flex items-start gap-3">
              <span class="text-2xl">🎯</span>
              <div>
                <h4 class="text-sm font-bold text-dark mb-1">Quando escolher</h4>
                <p class="text-sm text-muted leading-relaxed">${tech.quandoEscolher}</p>
              </div>
            </div>
          </div>

          <div class="mt-5">
            <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-3">Marcas que oferecem</h4>
            <div class="flex flex-wrap gap-2">
              ${tech.marcasQueOferecem.map((m) => `<span class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-semibold">${m}</span>`).join('')}
            </div>
          </div>

          <a href="https://wa.me/5561998805002?text=${encodeURIComponent(`Oi! Quero saber mais sobre ${tech.nome} pra meu sistema solar`)}" target="_blank" rel="noopener" class="mt-6 w-full inline-flex items-center justify-center gap-2 bg-primary-500 hover:bg-primary-600 text-white font-bold text-sm px-5 py-3 rounded-full transition-colors">
            Quero ${tech.nome} no meu sistema
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    `;
  }

  function openModal(key) {
    const marca = marcasMap[key];
    if (!marca || !modal) return;
    renderModal(marca);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      modal.setAttribute('data-state', 'open');
    });
  }

  function openTechModal(techName) {
    const tech = techMap[techName];
    if (!tech || !modal) return;
    renderTechModal(tech);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      modal.setAttribute('data-state', 'open');
    });
  }

  function closeModal() {
    if (!modal) return;
    modal.setAttribute('data-state', 'closed');
    document.body.style.overflow = '';
    // Espera animação terminar antes de hide
    setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }, 200);
  }

  // Click handlers nas marcas
  document.querySelectorAll('.marca-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-marca');
      if (key) openModal(key);
    });
  });

  // Click handlers nas tecnologias
  document.querySelectorAll('.tech-badge').forEach((btn) => {
    btn.addEventListener('click', () => {
      const techName = btn.getAttribute('data-tech');
      if (techName) openTechModal(techName);
    });
  });

  // Click handlers — fecha se NÃO clicou dentro do card (qualquer lugar fora fecha)
  modal?.addEventListener('mousedown', (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    // Se clicou dentro do card content, NÃO fecha (exceto no botão X)
    if (target.closest('#marca-modal-content') && !target.closest('.modal-close-btn')) {
      return;
    }
    // Caso contrário (fora do card OU no X), fecha
    closeModal();
  });

  // Esc fecha
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>

---
// Trust Bar PREMIUM — marcas clicáveis com ficha técnica
// Cliente clica na marca → modal abre com info detalhada

interface Marca {
  nome: string;
  origem: string;
  destaque: string;
  pontos: string[];
  tecnologias?: string[];
  ecosunUsa?: string;
}

interface Categoria {
  titulo: string;
  icon: string;
  cor: string;
  marcas: Marca[];
}

interface Tecnologia {
  nome: string;
  oQueE: string;
  vantagens: string[];
  quandoEscolher: string;
  marcasQueOferecem: string[];
  icon: string;
}


---
import config from '../content/config-site.json';
import { supabase } from '../lib/supabase-build';

interface ReviewCard {
  id: string;
  nomeCliente: string;
  cidade: string | null;
  texto: string | null;
  estrelas: number;
  googlePosted: boolean;
  data: string;
  fonte: 'eva' | 'site';
}

function abreviarNome(full: string | null): string {
  if (!full) return 'Cliente';
  const parts = full.trim().split(/\s+/);
  if (parts.length === 1) return parts[0];
  return `${parts[0]} ${parts[parts.length - 1][0]}.`;
}

const reviews: ReviewCard[] = [];

// Fonte 1: depoimentos coletados pela Eva via WhatsApp (testimonials.json endpoint)
const siteUrl = Astro.site?.toString() ?? 'https://ecosunpower.eng.br/';
try {
  const res = await fetch(`${siteUrl}api/testimonials.json`);
  if (res.ok) {
    const arr: any[] = await res.json();
    for (const t of arr) {
      if (t.texto && t.texto.length > 0) {
        reviews.push({
          id: `eva-${t.id}`,
          nomeCliente: t.nomeCliente,
          cidade: t.cidade,
          texto: t.texto,
          estrelas: t.estrelas,
          googlePosted: t.googlePosted,
          data: t.data,
          fonte: 'eva',
        });
      }
    }
  }
} catch (err) {
  console.warn('[Depoimentos] fetch testimonials.json falhou:', err);
}

// Fonte 2: avaliacoes publicas via formulario /avaliar (tabela public_reviews)
if (supabase) {
  const { data, error } = await supabase
    .from('public_reviews')
    .select('id, cliente_nome, cliente_cidade, estrelas, texto, created_at')
    .eq('approved_for_marketing', true)
    .not('texto', 'is', null)
    .order('created_at', { ascending: false })
    .limit(20);

  if (!error && data) {
    for (const r of data as any[]) {
      reviews.push({
        id: `site-${r.id}`,
        nomeCliente: abreviarNome(r.cliente_nome),
        cidade: r.cliente_cidade,
        texto: r.texto,
        estrelas: r.estrelas,
        googlePosted: false,
        data: r.created_at,
        fonte: 'site',
      });
    }
  }
}

// Combina e ordena por mais recente, limita a 6 cards
const comTexto = reviews
  .sort((a, b) => new Date(b.data).getTime() - new Date(a.data).getTime())
  .slice(0, 6);
---

<section class="py-16 lg:py-24 bg-navy border-t border-navy-line">
  <div class="container-wide">
    <div class="mb-10 text-center">
      <h2 class="mb-3 text-3xl lg:text-4xl font-display font-bold text-ink">O que nossos clientes dizem</h2>
      <div class="inline-flex items-center gap-2 rounded-full bg-accent-500/10 border border-accent-500/25 px-4 py-2 text-accent-500">
        <span class="text-xl">⭐</span>
        <span class="font-bold">{config.googleNota} no Google</span>
        <span class="text-sm text-ink-mut">· {config.googleQtdAvaliacoes} avaliações</span>
      </div>
    </div>

    {comTexto.length === 0 ? (
      <div class="text-center text-ink-mut">
        <p>Em breve, depoimentos reais dos nossos clientes aqui.</p>
        <p class="mt-2 text-sm">Enquanto isso, veja as avaliações no Google:</p>
        <a href={config.googleUrl} target="_blank" rel="noopener" class="btn-primary mt-4 inline-block">
          Ver avaliações no Google
        </a>
      </div>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {comTexto.map(t => (
          <article class="flex flex-col rounded-2xl p-6 bg-navy-600 border border-navy-line">
            <div class="mb-3 flex items-center gap-2">
              {Array.from({ length: t.estrelas }).map(() => <span class="text-amber-400">⭐</span>)}
            </div>
            <blockquote class="mb-4 flex-1 text-base leading-relaxed text-ink-mut">
              "{t.texto}"
            </blockquote>
            <footer class="border-t border-navy-line pt-3 text-sm">
              <div class="font-semibold text-ink">{t.nomeCliente}</div>
              {t.cidade && <div class="text-ink-mut2">{t.cidade}</div>}
              {t.googlePosted && (
                <div class="mt-2 inline-flex items-center gap-1 text-xs text-green-500">
                  ✓ Verificado no Google
                </div>
              )}
            </footer>
          </article>
        ))}
      </div>
    )}

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href={config.googleUrl} target="_blank" rel="noopener" class="btn-secondary">Ver no Google</a>
      <a href="/avaliar" class="btn-primary">Avalie a gente</a>
    </div>
    <p class="mt-4 text-center text-xs text-ink-mut2">Avaliação rápida no nosso site, sem precisar de conta Google.</p>
  </div>
</section>

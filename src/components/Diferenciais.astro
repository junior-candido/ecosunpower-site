---
const diferenciais = [
  {
    icon: '⚡',
    title: 'Baterias e BESS',
    desc: 'Armazenamento de energia que funciona. Independência da rede 24h.',
    tag: 'Diferencial',
  },
  {
    icon: '🌞',
    title: 'Grid Zero',
    desc: 'Sistema sem injeção na rede — autoconsumo total. Ideal pra empresas.',
    tag: 'Avançado',
  },
  {
    icon: '🔄',
    title: 'Sistema Híbrido',
    desc: 'Solar + bateria + rede. O melhor de cada mundo, sem comprometer nada.',
    tag: 'Premium',
  },
  {
    icon: '🏭',
    title: 'Grupo A (Indústria)',
    desc: 'Projetos de média tensão pra indústrias. Engenharia robusta.',
    tag: 'Especializado',
  },
  {
    icon: '📐',
    title: 'Engenharia Própria',
    desc: 'Projeto, ART, memorial, instalação — tudo feito pelo nosso time.',
    tag: 'Garantia',
  },
  {
    icon: '🔌',
    title: 'Mercado Livre',
    desc: 'Migração pro Mercado Livre de Energia com solar — economia máxima.',
    tag: 'Estratégico',
  },
];
---

<section id="diferenciais" class="section bg-surface-alt">
  <div class="container-wide">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="tag">Por que EcoSunPower</span>
      <h2 class="text-4xl lg:text-5xl mt-4 mb-5">
        Tecnologia que vai <span class="text-gradient">além do painel</span>
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        Nossa diferença não está em vender solar — está em projetar a solução certa
        com baterias, automação e engenharia profunda. É por isso que clientes
        nos escolhem pra projetos complexos.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {diferenciais.map((d) => (
        <div class="card group hover:-translate-y-1">
          <div class="flex items-start justify-between mb-4">
            <div class="text-4xl">{d.icon}</div>
            <span class="tag-accent">{d.tag}</span>
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-primary-600 transition-colors">
            {d.title}
          </h3>
          <p class="text-muted text-sm leading-relaxed">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
